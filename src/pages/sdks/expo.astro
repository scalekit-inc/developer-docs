---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { Badge, Code } from '@astrojs/starlight/components'
import { getCollection, render } from 'astro:content'
import SDKInstallPanel from '@components/SDKInstallPanel.astro'
import '@/styles/sdk-reference.css'

const allReleases = await getCollection('github-releases', (entry) => {
  const data = entry.data as any
  return data.repoNameWithOwner === 'scalekit-inc/scalekit-expo-sdk'
})

const releases = allReleases
  .sort((a, b) => {
    const dataA = a.data as any
    const dataB = b.data as any
    const dateA = dataA.publishedAt ? new Date(dataA.publishedAt).getTime() : 0
    const dateB = dataB.publishedAt ? new Date(dataB.publishedAt).getTime() : 0
    return dateB - dateA
  })
  .slice(0, 10)

const latestRelease = releases.length > 0 ? (releases[0].data as any) : null

const headings = [
  { depth: 2, slug: 'installation', text: 'Install' },
  { depth: 2, slug: 'provider-setup', text: 'Provider setup' },
  { depth: 2, slug: 'usescalekit-hook', text: 'useScalekit hook' },
  ...(releases.length > 0 ? [{ depth: 2, slug: 'changelog', text: 'Changelog' }] : []),
]

const frontmatter = {
  title: 'Expo SDK',
  topic: 'saaskit-sdks',
  template: 'doc' as const,
  tableOfContents: false,
  sidebar: {
    label: 'Expo',
  },
  prev: false,
  next: false,
}
---

<StarlightPage frontmatter={frontmatter} hasSidebar={true} headings={headings}>
  <SDKInstallPanel
    githubHref="https://github.com/scalekit-inc/scalekit-expo-sdk"
    version={latestRelease?.tagName}
    badges={['TypeScript', 'React Hooks']}
    updatedAt={latestRelease?.publishedAt}
  >
    <Code
      code="npx expo install @scalekit-sdk/expo"
      lang="bash"
      showLineNumbers={false}
      frame="none"
    />
  </SDKInstallPanel>

  <section class="sdk-page-section" aria-labelledby="provider-setup">
    <h2 id="provider-setup">Provider setup</h2>
    <Code
      code={`import { ScalekitProvider } from '@scalekit-sdk/expo';

export default function App() {
  return (
    <ScalekitProvider
      envUrl="https://your-env.scalekit.com"
      clientId="your-client-id"
    >
      {/* Your app components */}
    </ScalekitProvider>
  );
}`}
      lang="tsx"
      frame="none"
      showLineNumbers={false}
    />
  </section>

  <section class="sdk-page-section" aria-labelledby="usescalekit-hook">
    <h2 id="usescalekit-hook">useScalekit hook</h2>
    <Code
      code={`import { useScalekit } from '@scalekit-sdk/expo';
import { View, Button, Text } from 'react-native';

function LoginScreen() {
  const { login, logout, user, isAuthenticated, isLoading } = useScalekit();

  if (isLoading) {
    return <Text>Loading...</Text>;
  }

  if (isAuthenticated) {
    return (
      <View>
        <Text>Welcome, {user?.name}!</Text>
        <Button title="Logout" onPress={logout} />
      </View>
    );
  }

  return <Button title="Login" onPress={login} />;
}`}
      lang="tsx"
      frame="none"
      showLineNumbers={false}
    />
  </section>

  {
    releases.length > 0 && (
      <section class="sdk-changelog" id="changelog">
        <div class="sdk-changelog__head">
          <h2 class="sdk-changelog__title">Changelog</h2>
          <a
            href="https://github.com/scalekit-inc/scalekit-expo-sdk/releases"
            target="_blank"
            rel="noopener noreferrer"
            class="sdk-changelog__all"
          >
            View all releases →
          </a>
        </div>
        <div class="sdk-changelog__list">
          {await Promise.all(
            releases.map(async (release) => {
              const { Content } = await render(release)
              const data = release.data as any
              return (
                <article class="sdk-changelog__item">
                  <div class="sdk-changelog__item-head">
                    <Badge text={data.tagName} variant="default" />
                    {data.isPrerelease && <Badge text="Pre-release" variant="note" />}
                    {data.isDraft && <Badge text="Draft" variant="note" />}
                    {data.publishedAt && (
                      <time datetime={data.publishedAt} class="sdk-changelog__date">
                        {new Date(data.publishedAt).toLocaleDateString('en-US', {
                          year: 'numeric',
                          month: 'short',
                          day: 'numeric',
                        })}
                      </time>
                    )}
                  </div>
                  <div class="sdk-changelog__body">
                    <Content />
                  </div>
                </article>
              )
            }),
          )}
        </div>
      </section>
    )
  }
</StarlightPage>
