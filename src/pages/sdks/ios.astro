---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import { Badge, Code } from '@astrojs/starlight/components'
import { getCollection } from 'astro:content'
import SDKInstallPanel from '@components/SDKInstallPanel.astro'
import '@/styles/sdk-reference.css'

const allReleases = await getCollection('github-releases', (entry) => {
  const data = entry.data as any
  return data.repoNameWithOwner === 'scalekit-inc/scalekit-sdk-ios'
})

const releases = allReleases
  .sort((a, b) => {
    const dataA = a.data as any
    const dataB = b.data as any
    const dateA = dataA.publishedAt ? new Date(dataA.publishedAt).getTime() : 0
    const dateB = dataB.publishedAt ? new Date(dataB.publishedAt).getTime() : 0
    return dateB - dateA
  })
  .slice(0, 10)

const latestRelease = releases.length > 0 ? (releases[0].data as any) : null
const latestTag = latestRelease?.tagName as string | undefined

const headings = [
  { depth: 2, slug: 'installation', text: 'Install' },
  { depth: 2, slug: 'initialize', text: 'Initialize' },
  { depth: 2, slug: 'auth-and-sessions', text: 'Auth and sessions' },
]

const frontmatter = {
  title: 'iOS SDK',
  topic: 'saaskit-sdks',
  template: 'doc' as const,
  tableOfContents: false,
  sidebar: {
    label: 'iOS',
  },
  prev: false,
  next: false,
}
---

<StarlightPage frontmatter={frontmatter} hasSidebar={true} headings={headings}>
  <SDKInstallPanel
    githubHref="https://github.com/scalekit-inc/scalekit-sdk-ios"
    version={latestTag}
    badges={['Swift', 'SPM', 'iOS 15+']}
    updatedAt={latestRelease?.publishedAt}
  >
    <div slot="note">
      <p>
        In Xcode: <strong>File → Add Package Dependencies</strong>, paste this URL:
      </p>
    </div>
    <Code
      code="https://github.com/scalekit-inc/scalekit-sdk-ios"
      lang="text"
      showLineNumbers={false}
      frame="none"
    />
  </SDKInstallPanel>
  <p class="sdk-install-follow">
    Set version rule to <code>from: "0.3.0"</code>, select your app target, then click
    <strong>Add Package</strong>.
  </p>

  <section class="sdk-page-section" aria-labelledby="initialize">
    <h2 id="initialize">Initialize</h2>
    <Code
      code={`import ScalekitAuth

@StateObject private var client = ScalekitClient(
    environmentURL: "YOUR_ENV_URL",      // e.g. acme.scalekit.cloud
    clientId: "YOUR_CLIENT_ID",          // starts with ntvc_
    redirectScheme: "YOUR_BUNDLE_ID"     // e.g. com.example.myapp
)`}
      lang="swift"
      frame="none"
      showLineNumbers={false}
    />
  </section>

  <section class="sdk-page-section" aria-labelledby="auth-and-sessions">
    <h2 id="auth-and-sessions">Auth and sessions</h2>
    <Code
      code={`// Basic login
try await client.login()

// With organization routing (SSO)
try await client.login(options: .init(organizationId: "org_123456"))

// Access user information
if let user = client.credentials?.userInfo {
    print(user.name)   // "Jane Doe"
    print(user.email)  // "jane@acme.com"
}

// Refresh the access token before protected API calls (no-op if still valid)
try await client.renew()
let accessToken = client.credentials?.accessToken

// Logout
await client.logout()`}
      lang="swift"
      frame="none"
      showLineNumbers={false}
    />
  </section>
</StarlightPage>

<style>
  .sdk-install-follow {
    margin: -1rem 0 1.75rem;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--sl-color-text-muted);
  }

  .sdk-install-follow code {
    font-size: 0.8125em;
  }
</style>
