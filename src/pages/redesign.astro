---
// Standalone reference page — no Starlight layout
// Scalekit website redesign concept for internal team review
export const prerender = true
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scalekit website redesign — reference</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #0a0a0f;
        --surface: #0d0d14;
        --surface-alt: #080810;
        --border: #1e293b;
        --text: #f1f5f9;
        --text-muted: #64748b;
        --text-dim: #475569;
        --purple: #6366f1;
        --purple-light: #818cf8;
        --purple-bg: #12101f;
        --purple-border: #6366f1;
        --green: #10b981;
        --green-light: #6ee7b7;
        --green-bg: #0d1f16;
        --green-border: #10b981;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        line-height: 1.6;
      }

      /* ── Page header ── */
      .page-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #050508;
        border-bottom: 1px solid var(--border);
        padding: 0.6rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .page-header-left {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .page-badge {
        font-size: 0.65rem;
        font-family: monospace;
        background: #1e1b4b;
        color: var(--purple-light);
        border: 1px solid var(--purple);
        border-radius: 0.2rem;
        padding: 0.2rem 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .page-header nav {
        display: flex;
        gap: 0;
      }
      .page-header nav a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.75rem;
        padding: 0.3rem 0.75rem;
        border-radius: 0.2rem;
        transition: color 0.15s;
      }
      .page-header nav a:hover {
        color: var(--text);
        background: #111827;
      }
      .page-header-right {
        font-size: 0.7rem;
        color: var(--text-dim);
        font-family: monospace;
      }

      /* ── Sections ── */
      .section {
        max-width: 960px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        border-bottom: 1px solid var(--border);
      }
      .section:last-child {
        border-bottom: none;
      }

      .section-label {
        font-size: 0.65rem;
        font-family: monospace;
        color: var(--text-dim);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.5rem;
      }
      .section-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
      }
      .section-desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        max-width: 600px;
        margin-bottom: 2rem;
      }

      /* ── Mockup frame ── */
      .mockup {
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        overflow: hidden;
      }
      .mockup-bar {
        background: #111827;
        border-bottom: 1px solid var(--border);
        padding: 0.5rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .mockup-bar .dots {
        display: flex;
        gap: 0.35rem;
      }
      .mockup-bar .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
      }
      .mockup-bar .dot-red {
        background: #ef4444;
      }
      .mockup-bar .dot-yellow {
        background: #f59e0b;
      }
      .mockup-bar .dot-green {
        background: #22c55e;
      }
      .mockup-bar .url {
        flex: 1;
        background: #1e293b;
        border-radius: 0.25rem;
        padding: 0.2rem 0.75rem;
        font-size: 0.7rem;
        font-family: monospace;
        color: var(--text-muted);
      }

      /* ── Site homepage mockup ── */
      .site-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1.5rem;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
      }
      .site-nav-left {
        display: flex;
        align-items: center;
        gap: 2rem;
      }
      .site-logo {
        color: #e2e8f0;
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: -0.02em;
      }
      .site-nav-links {
        display: flex;
        gap: 1.5rem;
        font-size: 0.78rem;
      }
      .site-nav-right {
        display: flex;
        gap: 0.75rem;
        align-items: center;
      }
      .btn-signin {
        color: var(--text-muted);
        font-size: 0.75rem;
        cursor: pointer;
      }
      .btn-start {
        background: var(--purple);
        color: white;
        padding: 0.3rem 0.75rem;
        border-radius: 0.25rem;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
      }

      .hero {
        padding: 3rem 2.5rem 2rem;
        background: var(--bg);
      }
      .eyebrow {
        font-size: 0.68rem;
        color: var(--purple);
        font-family: monospace;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
      }
      .hero h1 {
        font-size: 2.4rem;
        font-weight: 800;
        line-height: 1.15;
        color: var(--text);
        margin-bottom: 1.25rem;
        letter-spacing: -0.03em;
        max-width: 640px;
      }
      .hero h1 span {
        color: #94a3b8;
      }
      .hero-body {
        font-size: 1rem;
        color: var(--text-muted);
        max-width: 560px;
        line-height: 1.7;
        margin-bottom: 2rem;
      }
      .hero-body em {
        color: #94a3b8;
        font-style: normal;
      }

      .diagram-box {
        background: #f8f9ff;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 2rem;
        border: 1px solid var(--border);
      }
      .diagram-box img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 0.25rem;
      }

      .two-doors {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
      }
      .door {
        border-radius: 0.5rem;
        padding: 1.25rem;
      }
      .door-agents {
        background: var(--purple-bg);
        border: 1px solid var(--purple-border);
      }
      .door-apps {
        background: var(--green-bg);
        border: 1px solid var(--green-border);
      }
      .door-label {
        font-size: 0.65rem;
        font-family: monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.4rem;
      }
      .door-agents .door-label {
        color: var(--purple-light);
      }
      .door-apps .door-label {
        color: var(--green);
      }
      .door-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.5rem;
      }
      .door-body {
        font-size: 0.78rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 1rem;
      }
      .code-snippet {
        background: var(--bg);
        border-radius: 0.25rem;
        padding: 0.75rem;
        font-family: monospace;
        font-size: 0.7rem;
        margin-bottom: 1rem;
        border: 1px solid var(--border);
        line-height: 1.7;
      }
      .door-cta {
        font-size: 0.8rem;
        font-weight: 600;
      }
      .door-agents .door-cta {
        color: var(--purple-light);
      }
      .door-apps .door-cta {
        color: var(--green);
      }

      .below-fold {
        padding: 2rem 2.5rem;
        background: var(--surface-alt);
        border-top: 1px solid var(--border);
      }
      .modular-label {
        font-size: 0.68rem;
        color: var(--text-dim);
        font-family: monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.25rem;
      }
      .modular-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
        margin-bottom: 2rem;
      }
      .modular-card {
        background: #111827;
        border: 1px solid var(--border);
        border-radius: 0.375rem;
        padding: 0.75rem;
        text-align: center;
      }
      .modular-card-title {
        font-size: 0.78rem;
        color: #e2e8f0;
        font-weight: 600;
        margin-bottom: 0.25rem;
      }
      .modular-card-desc {
        font-size: 0.68rem;
        color: var(--text-dim);
      }
      .trust-strip {
        display: flex;
        gap: 2rem;
        align-items: center;
        border-top: 1px solid var(--border);
        padding-top: 1.25rem;
        flex-wrap: wrap;
      }
      .trust-badge {
        font-size: 0.72rem;
        color: var(--text-dim);
        font-family: monospace;
      }

      /* ── Sitemap ── */
      .sitemap-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }
      .sitemap-panel {
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        overflow: hidden;
      }
      .sitemap-header {
        padding: 0.6rem 1rem;
        font-family: monospace;
        font-size: 0.8rem;
        font-weight: 600;
      }
      .sitemap-header.human {
        background: #1a1a2e;
        color: #e2e8f0;
      }
      .sitemap-header.agent {
        background: #0f172a;
        color: #7dd3fc;
      }
      .sitemap-body {
        padding: 1.25rem;
        font-family: monospace;
        font-size: 0.75rem;
        line-height: 1.9;
        background: var(--surface);
      }
      .sm-section {
        font-weight: 700;
        margin-top: 0.5rem;
      }
      .sm-section.purple {
        color: var(--purple);
      }
      .sm-section.green {
        color: var(--green);
      }
      .sm-section.blue {
        color: #7dd3fc;
      }
      .sm-section.gray {
        color: var(--text-muted);
      }
      .sm-items {
        padding-left: 1rem;
        color: #94a3b8;
        margin-bottom: 0.5rem;
      }
      .sm-note {
        color: var(--text-dim);
        font-size: 0.68rem;
      }

      /* ── Pricing ── */
      .pricing-tabs {
        display: flex;
        gap: 0;
        margin-bottom: 0;
        border-bottom: 2px solid var(--border);
      }
      .pricing-tab {
        padding: 0.6rem 1.25rem;
        border: none;
        cursor: pointer;
        font-size: 0.78rem;
        font-weight: 600;
        font-family: monospace;
        background: #1e293b;
        color: var(--text-muted);
        transition: all 0.15s;
      }
      .pricing-tab.active-purple {
        background: var(--purple);
        color: white;
      }
      .pricing-tab.active-green {
        background: var(--green);
        color: white;
      }
      .pricing-view {
        display: none;
        padding: 1.5rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-top: none;
        border-radius: 0 0 0.5rem 0.5rem;
      }
      .pricing-view.active {
        display: block;
      }

      .pricing-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.78rem;
        margin-bottom: 1.25rem;
      }
      .pricing-table th {
        text-align: left;
        padding: 0.5rem 0.75rem;
        color: var(--text-muted);
        font-weight: 600;
        border-bottom: 1px solid var(--border);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .pricing-table td {
        padding: 0.65rem 0.75rem;
        border-bottom: 1px solid #111827;
        color: #94a3b8;
      }
      .pricing-table td:first-child {
        color: var(--text);
        font-weight: 600;
      }
      .pricing-table td.price {
        color: var(--green);
        font-weight: 700;
        font-family: monospace;
      }
      .pricing-note {
        font-size: 0.72rem;
        color: var(--text-dim);
        font-family: monospace;
        line-height: 1.8;
      }

      /* ── Docs experience ── */
      .docs-tabs {
        display: flex;
        gap: 0;
        margin-bottom: 0;
        border-bottom: 2px solid var(--border);
      }
      .docs-tab {
        padding: 0.6rem 1.25rem;
        border: none;
        cursor: pointer;
        font-size: 0.75rem;
        font-weight: 600;
        font-family: monospace;
        background: #1e293b;
        color: var(--text-muted);
        transition: all 0.15s;
      }
      .docs-tab.active-agents {
        background: var(--purple);
        color: white;
      }
      .docs-tab.active-apps {
        background: var(--green);
        color: white;
      }
      .docs-tab.active-machine {
        background: #0ea5e9;
        color: white;
      }

      .docs-view {
        display: none;
        border: 1px solid var(--border);
        border-top: none;
        border-radius: 0 0 0.5rem 0.5rem;
        overflow: hidden;
      }
      .docs-view.active {
        display: block;
      }

      .docs-layout {
        display: grid;
        grid-template-columns: 200px 1fr 160px;
        min-height: 560px;
        font-family: monospace;
        font-size: 0.7rem;
      }
      .docs-sidebar {
        background: var(--bg);
        border-right: 1px solid var(--border);
        padding: 1rem 0;
      }
      .docs-sidebar-logo {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 0.75rem 0.75rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 0.75rem;
        color: #e2e8f0;
        font-weight: 700;
        font-size: 0.8rem;
      }
      .product-switcher {
        margin: 0 0.75rem 0.75rem;
        border-radius: 0.25rem;
        padding: 0.4rem 0.6rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .product-switcher.agents {
        background: var(--purple-bg);
        border: 1px solid var(--purple);
      }
      .product-switcher.apps {
        background: var(--green-bg);
        border: 1px solid var(--green);
      }
      .ps-icon {
        font-size: 0.62rem;
      }
      .ps-label {
        font-weight: 600;
        font-size: 0.68rem;
      }
      .ps-label.agents {
        color: var(--purple-light);
      }
      .ps-label.apps {
        color: var(--green);
      }
      .ps-toggle {
        color: var(--text-dim);
        margin-left: auto;
        font-size: 0.62rem;
      }

      .sidebar-group {
        padding: 0 0.75rem;
      }
      .sidebar-group-label {
        color: var(--text-dim);
        font-size: 0.58rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.4rem;
        margin-top: 0.75rem;
      }
      .sidebar-item {
        color: #94a3b8;
        padding: 0.28rem 0.5rem;
        margin-bottom: 0.15rem;
        border-radius: 0.2rem;
        cursor: pointer;
      }
      .sidebar-item.active-purple {
        color: var(--purple);
        background: #1e1b4b;
        font-weight: 600;
      }
      .sidebar-item.active-green {
        color: var(--green);
        background: #0d2a1c;
        font-weight: 600;
      }
      .sidebar-crossell {
        margin: 1rem 0.75rem 0;
        padding: 0.5rem;
        border-radius: 0.25rem;
        font-size: 0.62rem;
      }
      .sidebar-crossell.to-apps {
        background: #0d1a10;
        border: 1px solid #1e3a2f;
      }
      .sidebar-crossell.to-agents {
        background: #12101f;
        border: 1px solid #2e2a4b;
      }
      .sidebar-crossell-label {
        color: var(--text-dim);
        margin-bottom: 0.2rem;
      }
      .sidebar-crossell-link {
        font-weight: 600;
      }
      .sidebar-crossell.to-apps .sidebar-crossell-link {
        color: var(--green);
      }
      .sidebar-crossell.to-agents .sidebar-crossell-link {
        color: var(--purple-light);
      }

      .docs-main {
        background: #0d0d14;
        padding: 1.5rem;
        overflow-y: auto;
      }
      .docs-breadcrumb {
        color: var(--text-dim);
        font-size: 0.6rem;
        margin-bottom: 0.75rem;
      }
      .docs-h1 {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
      }
      .docs-intro {
        color: var(--text-muted);
        font-size: 0.73rem;
        line-height: 1.7;
        margin-bottom: 1.25rem;
        max-width: 520px;
      }
      .docs-callout {
        border-radius: 0.375rem;
        padding: 0.75rem;
        margin-bottom: 1.25rem;
      }
      .docs-callout.agents {
        background: var(--purple-bg);
        border: 1px solid var(--purple);
      }
      .docs-callout.apps {
        background: var(--green-bg);
        border: 1px solid var(--green);
      }
      .docs-callout-label {
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.4rem;
      }
      .docs-callout.agents .docs-callout-label {
        color: var(--purple-light);
      }
      .docs-callout.apps .docs-callout-label {
        color: var(--green);
      }
      .docs-callout-body {
        font-size: 0.68rem;
        color: #94a3b8;
        line-height: 1.6;
      }
      .lang-tabs {
        display: flex;
        gap: 0;
        border-bottom: 1px solid var(--border);
        margin-bottom: 0;
      }
      .lang-tab {
        padding: 0.3rem 0.65rem;
        font-size: 0.65rem;
        cursor: pointer;
        color: var(--text-muted);
        border: none;
        background: transparent;
      }
      .lang-tab.active {
        color: var(--purple-light);
        border-bottom: 2px solid var(--purple);
      }
      .lang-code {
        background: var(--bg);
        border: 1px solid var(--border);
        border-top: none;
        border-radius: 0 0 0.3rem 0.3rem;
        padding: 0.75rem;
        font-size: 0.68rem;
        line-height: 1.7;
        color: #a5b4fc;
        margin-bottom: 1rem;
      }

      .docs-toc {
        background: var(--bg);
        border-left: 1px solid var(--border);
        padding: 1rem 0.75rem;
      }
      .docs-toc-label {
        font-size: 0.58rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-dim);
        margin-bottom: 0.5rem;
      }
      .docs-toc-item {
        font-size: 0.62rem;
        color: var(--text-dim);
        padding: 0.2rem 0;
        cursor: pointer;
      }
      .docs-toc-item:hover {
        color: #94a3b8;
      }
      .docs-mcp-widget {
        margin-top: 1.5rem;
        padding: 0.6rem;
        background: var(--purple-bg);
        border: 1px solid var(--purple);
        border-radius: 0.25rem;
      }
      .docs-mcp-label {
        font-size: 0.58rem;
        color: var(--purple-light);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 0.4rem;
      }
      .docs-mcp-code {
        font-size: 0.6rem;
        color: #94a3b8;
        line-height: 1.6;
      }

      /* ── docs.scalekit.com view ── */
      .agent-surface {
        padding: 1.5rem;
        background: #070d14;
        font-family: monospace;
        font-size: 0.72rem;
        line-height: 1.9;
      }
      .agent-surface h3 {
        color: #7dd3fc;
        font-size: 0.85rem;
        margin-bottom: 0.75rem;
        border-bottom: 1px solid #0e2a3a;
        padding-bottom: 0.4rem;
      }
      .agent-route {
        color: #7dd3fc;
        font-weight: 700;
      }
      .agent-note {
        color: var(--text-dim);
        padding-left: 1.5rem;
      }
      .agent-tool {
        color: #a5b4fc;
        padding-left: 1.5rem;
      }
      .agent-json {
        background: #0d0d14;
        border: 1px solid #0e2a3a;
        border-radius: 0.3rem;
        padding: 0.75rem;
        margin: 0.5rem 0 1rem;
        color: #94a3b8;
        font-size: 0.68rem;
      }

      /* ── Design tokens reference ── */
      .tokens-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
      }
      .token-card {
        border: 1px solid var(--border);
        border-radius: 0.375rem;
        overflow: hidden;
      }
      .token-swatch {
        height: 48px;
      }
      .token-info {
        padding: 0.5rem 0.6rem;
        background: var(--surface);
      }
      .token-name {
        font-size: 0.68rem;
        color: var(--text);
        font-weight: 600;
        font-family: monospace;
      }
      .token-value {
        font-size: 0.62rem;
        color: var(--text-muted);
        font-family: monospace;
      }

      /* ── Footer note ── */
      .page-footer {
        text-align: center;
        padding: 2rem;
        color: var(--text-dim);
        font-size: 0.75rem;
        border-top: 1px solid var(--border);
      }
      .page-footer a {
        color: var(--purple-light);
        text-decoration: none;
      }
      .page-footer a:hover {
        text-decoration: underline;
