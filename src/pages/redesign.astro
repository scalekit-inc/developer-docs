    <script>
      function showDocsTab(name) {
        ;['agents', 'apps', 'machine'].forEach((t) => {
          document.getElementById('dview-' + t).classList.remove('active')
          const tab = document.getElementById('dtab-' + t)
          tab.className = 'docs-tab'
        })
        document.getElementById('dview-' + name).classList.add('active')
        const activeTab = document.getElementById('dtab-' + name)
        if (name === 'agents') activeTab.classList.add('active-agents')
        else if (name === 'apps') activeTab.classList.add('active-apps')
        else activeTab.classList.add('active-machine')
      }

      function showPricingTab(name) {
        ;['agents', 'apps'].forEach((t) => {
          document.getElementById('pview-' + t).classList.remove('active')
          const tab = document.getElementById('ptab-' + t)
          tab.className = 'pricing-tab'
        })
        document.getElementById('pview-' + name).classList.add('active')
        const activeTab = document.getElementById('ptab-' + name)
        activeTab.classList.add(name === 'agents' ? 'active-purple' : 'active-green')
      }
    </script>
