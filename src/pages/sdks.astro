---
/**
 * Global SDKs entry — language cards + left sidebar (no splash shell).
 */
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import SDKCards from '@components/SDKCards.astro'
import '@/styles/pages/sdks.css'
import '@/styles/sdk-reference.css'

const frontmatter = {
  title: 'SDKs',
  description: 'Scalekit language SDKs for SaaSKit and AgentKit, plus Expo and iOS',
  template: 'doc' as const,
  topic: 'saaskit-sdks',
  tableOfContents: false,
  prev: false,
  next: false,
}
---

<StarlightPage frontmatter={frontmatter} hasSidebar={true}>
  <div class="sdk-hub-with-sidebar">
    <p>
      Install a language SDK from the cards below, or use the left sidebar to jump straight to a
      client (for example Organizations).
    </p>
    <SDKCards />
    <p style="margin-block-start: 1.5rem;">
      Building with agents? See <a href="/agentkit/sdks/">AgentKit SDKs</a> (Node.js and Python).
    </p>
  </div>
</StarlightPage>
