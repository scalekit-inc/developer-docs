---
import { getActiveSecondaryNavId, type SecondaryNavProps } from '../../utils/secondary-nav-utils'

const { entry } = Astro.props satisfies SecondaryNavProps

const activeId = getActiveSecondaryNavId(Astro.url.pathname, entry)
const isAgentKitActive = activeId?.startsWith('agentkit-') ?? false
const isSaaSKitActive = activeId?.startsWith('saaskit-') ?? false

const productLinks = [
  {
    label: 'AgentKit',
    href: '/agent-auth/quickstart/',
    isActive: isAgentKitActive,
  },
  {
    label: 'SaaSKit',
    href: '/authenticate/fsa/quickstart/',
    isActive: isSaaSKitActive,
  },
]
---

<nav class="product-toggle sl-hidden md:sl-flex" aria-label="Product switcher">
  {
    productLinks.map((link) => (
      <a
        href={link.href}
        class={`product-toggle__option ${link.isActive ? 'is-active' : ''}`}
        aria-current={link.isActive ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))
  }
</nav>

<style>
  .product-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.0625rem;
    margin-left: 0.5rem;
    padding: 0.125rem;
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 0.375rem;
    background: color-mix(in srgb, var(--sl-color-gray-7) 60%, var(--sl-color-bg));
  }

  .product-toggle__option {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.875rem;
    padding: 0.3125rem 0.75rem;
    border-radius: calc(0.375rem - 0.125rem);
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    font-weight: 550;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .product-toggle__option:not(.is-active):hover {
    background: color-mix(in srgb, var(--sl-color-white) 24%, transparent);
    color: var(--sl-color-gray-3);
  }

  .product-toggle__option:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .product-toggle__option.is-active {
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    box-shadow: 0 1px 1px rgba(15, 23, 42, 0.08);
  }

  .product-toggle__option.is-active:hover {
    color: var(--sl-color-text);
  }

  :root[data-theme='dark'] .product-toggle {
    border-color: var(--sl-color-gray-5);
    background: color-mix(in srgb, var(--sl-color-gray-6) 85%, var(--sl-color-bg));
  }

  :root[data-theme='dark'] .product-toggle__option {
    color: var(--sl-color-gray-2);
  }

  :root[data-theme='dark'] .product-toggle__option:not(.is-active):hover {
    background: color-mix(in srgb, var(--sl-color-white) 3%, transparent);
    color: var(--sl-color-gray-2);
  }

  @media (max-width: 60rem) {
    .product-toggle {
      margin-left: 0.375rem;
    }

    .product-toggle__option {
      padding-inline: 0.6875rem;
    }
  }
</style>
