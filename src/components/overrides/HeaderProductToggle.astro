---
import {
  getActiveSecondaryNavId,
  getActiveProduct,
  type SecondaryNavProps,
} from '../../utils/secondary-nav-utils'
import { IconLucideUsers, IconLucideBot } from '../../utils/icon-map'
import { IconLucideCheck } from '../../configs/secondary-nav.config'

const { entry } = Astro.props satisfies SecondaryNavProps

const searchParams = Astro.url.searchParams
const activeId = getActiveSecondaryNavId(Astro.url.pathname, entry, searchParams)
const activeProduct = getActiveProduct(Astro.url.pathname, entry?.data?.topic, searchParams)

// activeId !== null means the page is in the doc system with a known nav context.
// Shared items (rest-apis, sdks, etc.) live in SaasKit nav, so activeProduct covers them.
const isAgentKitActive = activeProduct === 'agentkit'
const isSaaSKitActive = activeProduct === 'saaskit' && activeId !== null
const hasSelection = isAgentKitActive || isSaaSKitActive

const activeLabel = isAgentKitActive ? 'AgentKit' : isSaaSKitActive ? 'Auth for SaaS' : null

const productLinks = [
  {
    label: 'AgentKit',
    description: 'Connect agents to apps',
    href: '/agentkit/quickstart/',
    isActive: isAgentKitActive,
    storageValue: 'agentkit',
    iconComponent: IconLucideBot,
  },
  {
    label: 'Auth for SaaS',
    description: 'Users, RBAC, SSO',
    href: '/authenticate/fsa/quickstart/',
    isActive: isSaaSKitActive,
    storageValue: 'saaskit',
    iconComponent: IconLucideUsers,
  },
]
---

<div class="product-phrase sl-hidden md:sl-flex" id="product-phrase">
  <div class="product-dropdown" id="product-dropdown">
    <button
      class={`product-dropdown__trigger${!hasSelection ? ' is-placeholder' : ''}`}
      aria-haspopup="listbox"
      aria-expanded="false"
      id="product-dropdown-trigger"
      data-has-selection={hasSelection ? 'true' : 'false'}
    >
      {!hasSelection && <span class="phrase-prefix">I'm working on...</span>}
      {
        hasSelection && (
          <span id="product-label" class="product-label">
            {activeLabel}
          </span>
        )
      }
      <svg
        class="chevron"
        width="10"
        height="10"
        viewBox="0 0 10 10"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M2 3.5L5 6.5L8 3.5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>
    <div class="product-dropdown__menu" role="listbox" aria-labelledby="product-dropdown-trigger">
      <div class="menu-section-label">Choose product</div>
      {
        productLinks.map((link) => {
          const IconComponent = link.iconComponent
          return (
            <a
              href={link.href}
              class={`product-dropdown__item ${link.isActive ? 'is-active' : ''}`}
              role="option"
              aria-selected={link.isActive}
              data-storage-value={link.storageValue}
              data-label={link.label}
              data-product-switch
            >
              <div class="item-icon-wrapper">
                {IconComponent && <IconComponent class="item-icon" />}
              </div>
              <div class="item-content">
                <span class="item-label">{link.label}</span>
                <span class="item-description">{link.description}</span>
              </div>
              <IconLucideCheck class="item-check-icon" />
            </a>
          )
        })
      }
    </div>
  </div>
</div>

<script>
  let productToggleAbort: AbortController | null = null

  function initProductToggle() {
    const trigger = document.getElementById('product-dropdown-trigger') as HTMLButtonElement | null
    const dropdown = document.getElementById('product-dropdown')
    if (!trigger || !dropdown) return

    productToggleAbort?.abort()
    productToggleAbort = new AbortController()
    const { signal } = productToggleAbort

    dropdown.classList.remove('is-open')
    trigger.setAttribute('aria-expanded', 'false')

    const getOptions = () =>
      Array.from(dropdown.querySelectorAll<HTMLElement>('.product-dropdown__item[role="option"]'))

    const openMenu = () => {
      dropdown.classList.add('is-open')
      trigger.setAttribute('aria-expanded', 'true')
    }

    const closeMenu = (restoreFocus = false) => {
      dropdown.classList.remove('is-open')
      trigger.setAttribute('aria-expanded', 'false')
      if (restoreFocus) trigger.focus()
    }

    const focusOption = (index: number) => {
      const options = getOptions()
      if (!options.length) return
      const next = ((index % options.length) + options.length) % options.length
      options[next]?.focus()
    }

    trigger.addEventListener(
      'click',
      (e) => {
        e.stopPropagation()
        if (dropdown.classList.contains('is-open')) closeMenu()
        else openMenu()
      },
      { signal },
    )

    trigger.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
          e.preventDefault()
          openMenu()
          const options = getOptions()
          const activeIndex = options.findIndex((o) => o.classList.contains('is-active'))
          focusOption(activeIndex >= 0 ? activeIndex : 0)
        } else if (e.key === 'Escape') {
          closeMenu(true)
        }
      },
      { signal },
    )

    dropdown.addEventListener(
      'keydown',
      (e) => {
        if (!dropdown.classList.contains('is-open')) return
        const options = getOptions()
        const currentIndex = options.findIndex((o) => o === document.activeElement)

        if (e.key === 'Escape') {
          e.preventDefault()
          closeMenu(true)
        } else if (e.key === 'ArrowDown') {
          e.preventDefault()
          focusOption(currentIndex + 1)
        } else if (e.key === 'ArrowUp') {
          e.preventDefault()
          focusOption(currentIndex <= 0 ? options.length - 1 : currentIndex - 1)
        } else if (e.key === 'Home') {
          e.preventDefault()
          focusOption(0)
        } else if (e.key === 'End') {
          e.preventDefault()
          focusOption(options.length - 1)
        }
      },
      { signal },
    )

    document.addEventListener(
      'click',
      (e) => {
        if (!dropdown.contains(e.target as Node) && e.target !== trigger) {
          closeMenu()
        }
      },
      { signal },
    )

    // Product switch: close menu + optimistic label/active state so chrome
    // updates before the soft navigation paints the new secondary nav.
    dropdown.addEventListener(
      'click',
      (e) => {
        const option = (e.target as Element | null)?.closest?.('[data-product-switch]')
        if (!(option instanceof HTMLElement)) return

        const label = option.getAttribute('data-label')
        const labelEl = trigger.querySelector('.product-label')
        const prefixEl = trigger.querySelector('.phrase-prefix')

        if (label) {
          if (labelEl) {
            labelEl.textContent = label
          } else if (prefixEl) {
            const span = document.createElement('span')
            span.id = 'product-label'
            span.className = 'product-label'
            span.textContent = label
            prefixEl.replaceWith(span)
            trigger.classList.remove('is-placeholder')
            trigger.setAttribute('data-has-selection', 'true')
          }
        }

        getOptions().forEach((item) => {
          const active = item === option
          item.classList.toggle('is-active', active)
          item.setAttribute('aria-selected', String(active))
        })

        closeMenu()
      },
      { signal },
    )
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductToggle, { once: true })
  } else {
    initProductToggle()
  }
  document.addEventListener('astro:page-load', initProductToggle)
</script>

<style>
  .product-phrase {
    display: inline-flex;
    align-items: center;
    margin-left: 0.75rem;
    white-space: nowrap;
  }

  .product-dropdown {
    position: relative;
  }

  .product-dropdown__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .product-label {
    font-weight: 600;
    color: var(--sl-color-text);
    text-decoration: underline;
    text-decoration-color: var(--sl-color-gray-4);
    text-underline-offset: 3px;
    transition:
      text-decoration-color 0.15s ease,
      color 0.15s ease;
  }

  .product-dropdown__trigger:hover .product-label {
    text-decoration-color: var(--sl-color-text);
  }

  .product-dropdown__trigger:focus-visible {
    outline: var(--sk-focus-ring, 2px solid var(--sl-color-accent));
    outline-offset: var(--sk-focus-offset, 2px);
    border-radius: var(--sk-radius-sm, 0.25rem);
  }

  .chevron {
    opacity: 0.6;
    transition: transform 0.15s ease;
    flex-shrink: 0;
  }

  .product-dropdown.is-open .chevron {
    transform: rotate(180deg);
  }

  .product-dropdown__menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 16rem;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: var(--sk-radius-lg, 0.5rem);
    box-shadow: var(--sk-shadow-menu);
    z-index: var(--sl-z-index-dropdown, 15);
    overflow: hidden;
    padding: 0.5rem;
  }

  .product-dropdown.is-open .product-dropdown__menu {
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .chevron {
      transition: none;
    }
  }

  .menu-section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    padding: 0.25rem 0.5rem 0.5rem;
    letter-spacing: 0.05em;
  }

  .product-dropdown__item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0.5rem;
    color: var(--sl-color-gray-1);
    text-decoration: none;
    border-radius: var(--sk-radius-md, 0.375rem);
    transition: background-color 0.1s ease;
    position: relative;
  }

  .product-dropdown__item:hover {
    background: var(--sl-color-gray-6);
  }

  .product-dropdown__item:focus-visible {
    outline: var(--sk-focus-ring, 2px solid var(--sl-color-accent));
    outline-offset: var(--sk-focus-offset, 2px);
  }

  .item-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .item-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .item-content {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
    min-width: 0;
  }

  .item-label {
    font-size: var(--sl-text-sm);
    font-weight: 500;
    line-height: 1.4;
    color: inherit;
  }

  .item-description {
    font-size: 0.75rem;
    line-height: 1.25;
    color: var(--sk-color-muted-text, var(--sl-color-gray-3));
  }

  .item-check-icon {
    width: 0.875rem;
    height: 0.875rem;
    color: var(--sk-color-success, var(--sl-color-green-high));
    flex-shrink: 0;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.15s ease,
      visibility 0.15s ease;
  }

  .product-dropdown__item.is-active {
    background: var(--sl-color-gray-6);
  }

  .product-dropdown__item.is-active .item-check-icon {
    opacity: 1;
    visibility: visible;
  }

  .product-dropdown__item.is-active .item-label {
    font-weight: 600;
  }

  :root[data-theme='dark'] .product-dropdown__menu {
    border-color: var(--sl-color-gray-4);
  }
</style>
