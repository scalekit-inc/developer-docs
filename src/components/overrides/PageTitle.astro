---
import StarlightPageActionsPageTitle from 'starlight-page-actions/overrides/PageTitle.astro'
import { AGENT_PLUGIN_HEADER } from '@/configs/agent-instructions'
const { description } = Astro.locals.starlightRoute.entry.data
---

<div class="page-title-wrapper">
  <StarlightPageActionsPageTitle />
  {description && <p class="page-description">{description}</p>}
</div>

<style>
  .page-title-wrapper {
    display: flex;
    flex-direction: column;
  }

  .page-title-wrapper :global(h1) {
    order: 1;
  }

  .page-description {
    order: 2;
    margin-top: 0.5rem;
    color: var(--sl-color-gray-2);
  }

  .page-title-wrapper :global(.actions-container) {
    order: 3;
    margin-top: 0.75rem;
  }

  /* Action buttons - match sk-secondary aesthetic */
  .page-title-wrapper :global(.actions-container .action-button) {
    background-color: var(--sl-color-bg);
    color: var(--sl-color-text);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    font-size: var(--sl-text-sm);
    padding: 0.5rem 1rem;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .page-title-wrapper :global(.actions-container .action-button:hover),
  .page-title-wrapper :global(.actions-container .action-button:focus-visible) {
    background-color: var(--sl-color-gray-6);
  }

  /* Dropdown menu */
  .page-title-wrapper :global(.actions-container .dropdown #dropdown-menu) {
    background-color: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    box-shadow:
      0 1px 2px 0 rgba(10, 10, 10, 0.05),
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  /* Dropdown items */
  .page-title-wrapper :global(.actions-container .dropdown-item) {
    color: var(--sl-color-text);
    transition: background-color 0.15s ease;
  }

  .page-title-wrapper :global(.actions-container .dropdown-item:hover) {
    background-color: var(--sl-color-gray-6);
  }
</style>

<script define:vars={{ agentPluginHeader: AGENT_PLUGIN_HEADER }}>
  // Intercept the "Copy Markdown" button from starlight-page-actions to prepend
  // agent plugin installation instructions before the copied content.
  const copyBtn = document.querySelector('#copy-markdown')
  if (copyBtn) {
    copyBtn.addEventListener(
      'click',
      async (e) => {
        e.stopImmediatePropagation()
        copyBtn.disabled = true
        let cls = 'copied'
        try {
          const res = await fetch(`${copyBtn.dataset.path}.md`)
          const md = await res.text()
          await navigator.clipboard.writeText(agentPluginHeader + md)
        } catch {
          cls = 'error'
        } finally {
          copyBtn.classList.add(cls)
          copyBtn.disabled = false
          setTimeout(() => copyBtn.classList.remove(cls), 3000)
        }
      },
      true, // capture phase — fires before the package's own listener
    )
  }
</script>
