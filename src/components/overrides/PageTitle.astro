---
import StarlightPageActionsPageTitle from 'starlight-page-actions/overrides/PageTitle.astro'
import { AGENT_PLUGIN_HEADER } from '@/configs/agent-instructions'
const { title, description, connectorIcon, connectorAuthType, connectorCategories } =
  Astro.locals.starlightRoute.entry.data
const isConnectorPage = Boolean(connectorIcon)
---

<div class="page-title-wrapper">
  {
    isConnectorPage ? (
      <>
        <div class="connector-title-row">
          <img src={connectorIcon} width="44" height="44" alt="" class="connector-logo" />
          <div class="connector-title-content">
            <div class="connector-heading-line">
              <h1 id="_top">{title}</h1>
              {connectorAuthType && (
                <span class="connector-chip auth-chip">{connectorAuthType}</span>
              )}
              {connectorCategories?.map((cat) => (
                <span class="connector-chip cat-chip">{cat}</span>
              ))}
            </div>
            {description && <p class="page-description">{description}</p>}
          </div>
        </div>
        {/* display:contents lets the action buttons become direct flex children,
            preserving the existing order:3 rule while hiding the duplicate H1 */}
        <div class="actions-only">
          <StarlightPageActionsPageTitle />
        </div>
      </>
    ) : (
      <>
        <StarlightPageActionsPageTitle />
        {description && <p class="page-description">{description}</p>}
      </>
    )
  }
</div>

<style>
  .page-title-wrapper {
    display: flex;
    flex-direction: column;
  }

  /* ── Non-connector pages: reorder via flex order ── */
  .page-title-wrapper :global(h1) {
    order: 1;
  }

  .page-description {
    order: 2;
    margin-top: 0.375rem;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    line-height: 1.6;
  }

  .page-title-wrapper :global(.actions-container) {
    order: 3;
    margin-top: 0.75rem;
  }

  /* ── Connector page title layout ── */

  /* The connector-title-row is order:0 (default), appears before the action buttons (order:3) */
  .connector-title-row {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    order: 0;
  }

  .connector-logo {
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-6);
    background: var(--sl-color-bg);
    flex-shrink: 0;
    margin-top: 0.3rem;
  }

  .connector-title-content {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .connector-heading-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* Reset order on the H1 inside our custom row — it's already in the right place */
  .connector-heading-line :global(h1) {
    order: unset;
    margin: 0;
    line-height: 1.15;
  }

  /* Description sits inside connector-title-content, not as a flex child of page-title-wrapper */
  .connector-title-content .page-description {
    order: unset;
    margin-top: 0;
  }

  /* display:contents removes the wrapper box so action buttons participate
     directly in page-title-wrapper's flex layout, picking up order:3 */
  .actions-only {
    display: contents;
  }

  /* Hide the duplicate H1 that StarlightPageActionsPageTitle renders */
  .actions-only :global(h1) {
    display: none;
  }

  /* ── Chips ── */
  .connector-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem 0.55rem;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    white-space: nowrap;
    line-height: 1.4;
  }

  .auth-chip {
    background: color-mix(in srgb, var(--sl-color-blue) 10%, transparent);
    color: var(--sl-color-blue);
    border: 1px solid color-mix(in srgb, var(--sl-color-blue) 25%, transparent);
  }

  .cat-chip {
    background: color-mix(in srgb, var(--sl-color-gray-4) 12%, transparent);
    color: var(--sl-color-gray-2);
    border: 1px solid var(--sl-color-gray-5);
  }

  /* ── Action buttons — match sk-secondary aesthetic ── */
  .page-title-wrapper :global(.actions-container .action-button) {
    background-color: var(--sl-color-bg);
    color: var(--sl-color-text);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    font-size: var(--sl-text-sm);
    padding: 0.5rem 1rem;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .page-title-wrapper :global(.actions-container .action-button:hover),
  .page-title-wrapper :global(.actions-container .action-button:focus-visible) {
    background-color: var(--sl-color-gray-6);
  }

  .page-title-wrapper :global(.actions-container .dropdown #dropdown-menu) {
    background-color: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    box-shadow:
      0 1px 2px 0 rgba(10, 10, 10, 0.05),
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .page-title-wrapper :global(.actions-container .dropdown-item) {
    color: var(--sl-color-text);
    transition: background-color 0.15s ease;
  }

  .page-title-wrapper :global(.actions-container .dropdown-item:hover) {
    background-color: var(--sl-color-gray-6);
  }
</style>

<script define:vars={{ agentPluginHeader: AGENT_PLUGIN_HEADER }}>
  // Intercept the "Copy Markdown" button from starlight-page-actions to prepend
  // agent plugin installation instructions before the copied content.
  const copyBtn = document.querySelector('#copy-markdown')
  if (copyBtn) {
    copyBtn.addEventListener(
      'click',
      async (e) => {
        e.stopImmediatePropagation()
        copyBtn.disabled = true
        let cls = 'copied'
        try {
          const agentRes = await fetch(`${copyBtn.dataset.path}.agent.md`)
          const res = agentRes.ok ? agentRes : await fetch(`${copyBtn.dataset.path}.md`)
          if (!res.ok) throw new Error(`Failed to fetch markdown: ${res.status}`)
          const md = await res.text()
          await navigator.clipboard.writeText(agentPluginHeader + md)
        } catch {
          cls = 'error'
        } finally {
          copyBtn.classList.add(cls)
          copyBtn.disabled = false
          setTimeout(() => copyBtn.classList.remove(cls), 3000)
        }
      },
      true, // capture phase — fires before the package's own listener
    )
  }
</script>
