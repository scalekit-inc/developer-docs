---
import Default from '@astrojs/starlight/components/Head.astro'
---

<!-- LLM-friendly documentation directive — must appear first for AI agent discovery -->
<link rel="alternate" type="text/plain" title="LLM-friendly documentation" href="/llms.txt" />
<meta name="ai-content-type" content="documentation" />

<!--
  Navigation smoothness strategy (Starlight-aligned):
  - Do NOT use Astro <ClientRouter /> SPA mode. Starlight has no first-class
    support for it; DocSearch/Scalar/sidebar widgets often break after soft nav
    (see withastro/starlight#3447 and our Scalar blank-page bug).
  - Starlight already enables hover prefetch by default (prefetchAll).
  - Cross-document View Transitions are pure CSS in custom.css
    (@view-transition { navigation: auto }) — full page loads still run, so
    Scalar and other client SPAs mount correctly, with a short native cross-fade
    where the browser supports it.
-->

<!-- WebMCP: expose site tools to AI agents via the browser -->
<script src="/js/webmcp.js" defer></script>

<Default>
  <slot />
</Default>
