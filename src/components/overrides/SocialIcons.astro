---
import Default from '@astrojs/starlight/components/SocialIcons.astro'
---

<Default><slot /></Default>

<div class="flex items-center gap-4">
  <button
    id="auth-button"
    class="sk-primary inline-flex items-center justify-center bg-[var(--sl-color-accent)] px-4 py-2 text-sm font-semibold text-white hover:bg-[var(--sl-color-accent-high)] disabled:cursor-not-allowed disabled:opacity-50"
    >Start building auth</button
  >
</div>

<script>
  document.getElementById('auth-button')?.addEventListener('click', () => {
    window.location.href = 'https://www.scalekit.com'
  })
</script>
