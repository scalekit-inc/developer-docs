---
import Search from '@astrojs/starlight-docsearch/DocSearch.astro'
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro'
import SecondaryNav from '../SecondaryNav.astro'
import HeaderProductToggle from './HeaderProductToggle.astro'

import { LinkButton } from '@astrojs/starlight/components'
import MobileMenuToggle from '@astrojs/starlight/components/MobileMenuToggle.astro'
import AuthCTA from '../auth/AuthCTA.astro'

const { entry, locale } = Astro.props
---

{
  /*
  No transition:name / transition:persist — named regions morph from left/right/center.
  Page transitions are a single root fade in custom.css.
*/
}
<div class="header">
  <div class="top-row">
    <div class="header-left">
      <SiteTitle {locale} />
      <HeaderProductToggle entry={entry} />
    </div>

    <div class="header-center">
      <div class="search-wrapper">
        <Search {locale} />
        <MobileMenuToggle />
      </div>
    </div>

    <div class="header-right">
      <div class="right-actions sl-hidden md:sl-flex">
        <LinkButton
          href="https://schedule.scalekit.com/meet/ravi-madabhushi/demo-8b100203"
          target="_blank"
          variant="secondary"
          iconPlacement="start"
          class="sk-secondary"
        >
          Talk to an Engineer
        </LinkButton>
        <LinkButton
          href="https://app.scalekit.com/"
          variant="secondary"
          class="sk-secondary dashboard-btn"
          data-dashboard-btn
        >
          Dashboard
        </LinkButton>
        <AuthCTA />
        <!-- <div class="ml-4">
          <ThemeSelect />
        </div> -->
      </div>
    </div>
  </div>

  <SecondaryNav entry={entry} />
</div>

<script>
  // @ts-nocheck
  const STORAGE_KEY = 'sk_auth_session'

  const readCache = () => {
    try {
      const raw = localStorage.getItem(STORAGE_KEY)
      if (!raw) return null
      return JSON.parse(raw)
    } catch {
      return null
    }
  }

  /** @param {any} session */
  const writeCache = (session) => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(session))
    } catch {}
  }

  const clearCache = () => {
    try {
      localStorage.removeItem(STORAGE_KEY)
    } catch {}
  }

  /** @param {any} expiresAt */
  const isExpired = (expiresAt) => {
    if (!expiresAt) return false
    return Date.now() >= expiresAt
  }

  const getSession = async () => {
    const cached = readCache()
    if (cached?.authenticated && !isExpired(cached.expiresAt)) {
      return cached
    }

    clearCache()

    try {
      let response = await fetch('/auth/session', { credentials: 'include' })
      // Attempt refresh when access token has expired
      if (response.status === 401) {
        const refreshResponse = await fetch('/auth/refresh', {
          method: 'POST',
          credentials: 'include',
        })
        if (refreshResponse.ok) {
          response = await fetch('/auth/session', { credentials: 'include' })
        } else {
          clearCache()
          return { authenticated: false }
        }
      }
      if (!response.ok) {
        clearCache()
        return { authenticated: false }
      }

      const data = await response.json()
      if (data?.authenticated) {
        writeCache(data)
      } else {
        clearCache()
      }
      return data
    } catch {
      clearCache()
      return { authenticated: false }
    }
  }

  // Periodically refresh Dashboard button state without re-attaching listeners
  const refreshDashboardState = async (btn) => {
    const data = await getSession()
    if (data && data.authenticated) {
      btn.classList.add('is-authenticated')
    } else {
      btn.classList.remove('is-authenticated')
    }
  }

  function initDashboardButtons() {
    document.querySelectorAll('[data-dashboard-btn]').forEach(refreshDashboardState)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDashboardButtons, { once: true })
  } else {
    initDashboardButtons()
  }
  document.addEventListener('astro:page-load', initDashboardButtons)
</script>

<style>
  /* Layer declarations */
  @layer header.layout, header.components, header.responsive;

  /* =============================================================================
     LAYOUT LAYER - Container and structural styles
     ============================================================================= */
  @layer header.layout {
    .header {
      position: sticky;
      top: 0;
      z-index: var(--sl-z-index-navbar);
      background-color: var(--sl-color-bg);
    }

    .top-row {
      display: flex;
      align-items: center;
      width: 100%;
    }

    .header-left {
      flex: 1;
      display: flex;
      justify-content: flex-start;
      align-items: center;
      min-width: 0;
    }

    .header-center {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      max-width: 800px;
    }

    .header-right {
      flex: 1;
      display: flex;
      justify-content: flex-end;
      align-items: center;
    }
  }

  /* =============================================================================
     COMPONENTS LAYER - Individual component styles
     ============================================================================= */
  @layer header.components {
    .search-wrapper {
      flex: 0 1 300px;
      min-width: 250px;
    }

    .right-actions {
      display: none;
      gap: 1rem; /* Back to original spacing */
      align-items: center;
    }

    /* Shared control rhythm — equal height for primary + secondary in the toolbar */
    .right-actions :global(.sk-primary),
    .right-actions :global(.sk-secondary),
    .right-actions :global(.sk-minimal) {
      min-height: var(--sk-control-min-height, 2.25rem);
      padding: var(--sk-control-padding-y, 0.4rem) var(--sk-control-padding-x, 1.25rem);
      font-size: var(--sl-text-sm);
      border-radius: var(--sk-radius-md, 0.375rem);
    }

    .right-actions :global(.sk-secondary:hover) {
      background-color: var(--sl-color-gray-6);
    }

    .right-actions :global(.sk-primary:focus-visible),
    .right-actions :global(.sk-secondary:focus-visible),
    .right-actions :global(.sk-minimal:focus-visible) {
      outline: var(--sk-focus-ring, 2px solid var(--sl-color-accent));
      outline-offset: var(--sk-focus-offset, 2px);
    }

    /* Prevent any button text from wrapping to two lines */
    .right-actions :global(a) {
      white-space: nowrap;
    }

    /* Dashboard button: hidden by default, shown when authenticated */
    .dashboard-btn {
      display: none;
    }

    .dashboard-btn.is-authenticated {
      display: inline-flex;
    }
  }

  /* =============================================================================
     RESPONSIVE LAYER - Breakpoint-specific adaptations
     ============================================================================= */
  @layer header.responsive {
    /* Desktop: Show right actions with secondary nav (shared --sk-chrome-bp) */
    @media (min-width: 50rem) {
      .right-actions {
        display: flex;
      }
    }

    /* Large tablet adjustments */
    @media (max-width: 72rem) {
      .header-center {
        margin: 0 2rem;
      }

      .search-wrapper {
        flex: 0 1 250px;
        min-width: 200px;
      }
    }

    /* Small tablet adjustments */
    @media (max-width: 60rem) {
      .header-center {
        margin: 0 1rem;
      }

      .search-wrapper {
        flex: 0 1 200px;
        min-width: 180px;
      }
    }

    /* Mobile adjustments */
    @media (max-width: 48rem) {
      .header {
        position: sticky;
      }

      .top-row {
        height: auto;
        min-height: auto;
        gap: 0.5rem;
      }

      .header-left {
        flex: 0 0 auto;
        min-width: 0;
      }
    }
  }
</style>
