---
// Docs chatbot widget — ⌘K overlay style.
// Pure vanilla JS + SSE, no React dependency, CSS-isolated from the docs site.
const chatApiUrl = import.meta.env.PUBLIC_CHATBOT_API_URL ?? 'http://localhost:3001'
---

<!-- ⌘K overlay -->
<div id="sk-overlay" role="dialog" aria-modal="true" aria-label="Docs assistant" aria-hidden="true">
  <div id="sk-modal">
    <div id="sk-modal-header">
      <div id="sk-modal-header-left">
        <div id="sk-modal-icon">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="white"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            style="display:block"
          >
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </div>
        <span id="sk-modal-title">Docs assistant</span>
      </div>
      <div id="sk-modal-header-right">
        <span id="sk-modal-hint">Press <kbd>Esc</kbd> to close</span>
        <button id="sk-modal-close" aria-label="Close">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="white"
            stroke-width="2.5"
            stroke-linecap="round"
            style="display:block"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <div id="sk-messages">
      <div class="sk-msg sk-msg-assistant">
        <div class="sk-bubble sk-prose">
          Hi! Ask me anything about Scalekit — SSO, SCIM, Agent Auth, MCP, or full-stack auth. I'll
          search the docs and answer based on what's there.
        </div>
      </div>

      <div id="sk-suggestions">
        <button class="sk-suggestion" data-q="How do I set up SSO with Okta?"
          >How do I set up SSO with Okta?</button
        >
        <button class="sk-suggestion" data-q="How does SCIM provisioning work?"
          >How does SCIM provisioning work?</button
        >
        <button class="sk-suggestion" data-q="How do AI agents authenticate with OAuth?"
          >How do AI agents authenticate with OAuth?</button
        >
        <button class="sk-suggestion" data-q="What is Full Stack Auth?"
          >What is Full Stack Auth?</button
        >
      </div>
    </div>

    <div id="sk-input-area">
      <input
        id="sk-input"
        type="text"
        placeholder="Ask anything about Scalekit…"
        autocomplete="off"
        aria-label="Your question"
      />
      <button id="sk-send" aria-label="Send" disabled>
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="display:block"
        >
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
  </div>
</div>

<!-- Trigger pill -->
<button id="sk-trigger" aria-label="Ask the docs AI (⌘K)">
  <svg
    width="13"
    height="13"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    style="display:block;color:#6366f1"
  >
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
  <span>Ask AI</span>
  <kbd>⌘K</kbd>
</button>

<style>
  /* ── Reset: isolate from docs site global styles ── */
  #sk-overlay *,
  #sk-trigger,
  #sk-trigger * {
    all: unset;
    box-sizing: border-box;
  }

  /* ── Trigger pill ── */
  #sk-trigger {
    position: fixed !important;
    bottom: 24px !important;
    right: 24px !important;
    z-index: 9997 !important;
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
    padding: 8px 14px 8px 10px !important;
    background: #fff !important;
    border: 1px solid #e5e7eb !important;
    border-radius: 999px !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    font-size: 13px !important;
    font-weight: 500 !important;
    color: #374151 !important;
    cursor: pointer !important;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.08),
      0 0 0 1px rgba(0, 0, 0, 0.04) !important;
    transition:
      box-shadow 0.15s,
      border-color 0.15s !important;
    white-space: nowrap !important;
  }
  #sk-trigger:hover {
    border-color: #6366f1 !important;
    box-shadow:
      0 4px 14px rgba(99, 102, 241, 0.2),
      0 0 0 1px rgba(99, 102, 241, 0.2) !important;
  }
  #sk-trigger kbd {
    display: inline-flex !important;
    align-items: center !important;
    padding: 1px 5px !important;
    background: #f3f4f6 !important;
    border: 1px solid #d1d5db !important;
    border-radius: 4px !important;
    font-size: 11px !important;
    color: #6b7280 !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
  }

  /* ── Overlay backdrop ── */
  #sk-overlay {
    position: fixed !important;
    inset: 0 !important;
    z-index: 9999 !important;
    background: rgba(0, 0, 0, 0.45) !important;
    backdrop-filter: blur(4px) !important;
    -webkit-backdrop-filter: blur(4px) !important;
    display: flex !important;
    align-items: flex-start !important;
    justify-content: center !important;
    padding-top: 12vh !important;
    opacity: 0 !important;
    pointer-events: none !important;
    transition: opacity 0.18s ease !important;
  }
  #sk-overlay.sk-open {
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  /* ── Modal panel ── */
  #sk-modal {
    width: 100% !important;
    max-width: 640px !important;
    margin: 0 16px !important;
    background: #fff !important;
    border-radius: 16px !important;
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(0, 0, 0, 0.06) !important;
    display: flex !important;
    flex-direction: column !important;
    max-height: 72vh !important;
    overflow: hidden !important;
    transform: translateY(-8px) scale(0.98) !important;
    transition: transform 0.18s ease !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    font-size: 14px !important;
    line-height: 1.5 !important;
    color: #111827 !important;
  }
  #sk-overlay.sk-open #sk-modal {
    transform: translateY(0) scale(1) !important;
  }

  /* ── Header ── */
  #sk-modal-header {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 14px 16px !important;
    background: #6366f1 !important;
    flex-shrink: 0 !important;
    border-radius: 16px 16px 0 0 !important;
  }
  #sk-modal-header-left {
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
  }
  #sk-modal-icon {
    width: 30px !important;
    height: 30px !important;
    border-radius: 50% !important;
    background: rgba(255, 255, 255, 0.2) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    flex-shrink: 0 !important;
  }
  #sk-modal-title {
    font-size: 14px !important;
    font-weight: 600 !important;
    color: #fff !important;
  }
  #sk-modal-header-right {
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
  }
  #sk-modal-hint {
    font-size: 12px !important;
    color: rgba(255, 255, 255, 0.7) !important;
    display: flex !important;
    align-items: center !important;
    gap: 4px !important;
  }
  #sk-modal-hint kbd {
    display: inline-block !important;
    padding: 1px 5px !important;
    background: rgba(255, 255, 255, 0.2) !important;
    border-radius: 4px !important;
    font-size: 11px !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    color: rgba(255, 255, 255, 0.9) !important;
    border: 1px solid rgba(255, 255, 255, 0.25) !important;
  }
  #sk-modal-close {
    width: 28px !important;
    height: 28px !important;
    border-radius: 8px !important;
    background: rgba(255, 255, 255, 0.15) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    color: white !important;
    transition: background 0.15s !important;
    flex-shrink: 0 !important;
  }
  #sk-modal-close:hover {
    background: rgba(255, 255, 255, 0.28) !important;
  }

  /* ── Messages ── */
  #sk-messages {
    flex: 1 !important;
    overflow-y: auto !important;
    padding: 16px !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 12px !important;
    scroll-behavior: smooth !important;
    min-height: 120px !important;
  }
  #sk-messages::-webkit-scrollbar {
    width: 4px !important;
  }
  #sk-messages::-webkit-scrollbar-track {
    background: transparent !important;
  }
  #sk-messages::-webkit-scrollbar-thumb {
    background: #e5e7eb !important;
    border-radius: 4px !important;
  }

  .sk-msg {
    display: flex !important;
    flex-direction: column !important;
    width: 100% !important;
  }
  .sk-msg-user {
    align-items: flex-end !important;
  }
  .sk-msg-assistant {
    align-items: flex-start !important;
  }
  .sk-msg-error {
    align-items: flex-start !important;
  }

  .sk-bubble {
    max-width: 88% !important;
    padding: 10px 14px !important;
    border-radius: 12px !important;
    font-size: 13.5px !important;
    line-height: 1.6 !important;
    word-wrap: break-word !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    color: #111827 !important;
  }
  .sk-msg-user .sk-bubble {
    background: #6366f1 !important;
    color: #fff !important;
    border-bottom-right-radius: 4px !important;
    white-space: pre-wrap !important;
  }
  .sk-msg-assistant .sk-bubble {
    background: #f3f4f6 !important;
    border-bottom-left-radius: 4px !important;
  }
  .sk-msg-error .sk-bubble {
    background: #fef2f2 !important;
    color: #dc2626 !important;
    border: 1px solid #fecaca !important;
    border-bottom-left-radius: 4px !important;
  }

  /* ── Markdown prose inside assistant bubbles ── */
  .sk-prose p {
    display: block !important;
    margin: 0 0 8px !important;
  }
  .sk-prose p:last-child {
    margin-bottom: 0 !important;
  }
  .sk-prose h1,
  .sk-prose h2,
  .sk-prose h3 {
    display: block !important;
    font-weight: 600 !important;
    color: #111827 !important;
    margin: 12px 0 4px !important;
    line-height: 1.3 !important;
  }
  .sk-prose h1 {
    font-size: 16px !important;
  }
  .sk-prose h2 {
    font-size: 14.5px !important;
  }
  .sk-prose h3 {
    font-size: 13.5px !important;
  }
  .sk-prose ul,
  .sk-prose ol {
    display: block !important;
    margin: 6px 0 8px !important;
    padding-left: 18px !important;
  }
  .sk-prose li {
    display: list-item !important;
    margin: 3px 0 !important;
  }
  .sk-prose ul li {
    list-style-type: disc !important;
  }
  .sk-prose ol li {
    list-style-type: decimal !important;
  }
  .sk-prose strong {
    font-weight: 600 !important;
    color: #111827 !important;
  }
  .sk-prose em {
    font-style: italic !important;
  }
  .sk-prose a {
    color: #6366f1 !important;
    text-decoration: underline !important;
    cursor: pointer !important;
  }
  .sk-prose code {
    display: inline !important;
    background: #e5e7eb !important;
    padding: 1px 5px !important;
    border-radius: 4px !important;
    font-size: 12px !important;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace !important;
    color: #111827 !important;
  }
  .sk-prose pre {
    display: block !important;
    background: #1e1e2e !important;
    color: #cdd6f4 !important;
    border-radius: 8px !important;
    padding: 12px 14px !important;
    margin: 8px 0 !important;
    overflow-x: auto !important;
    font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace !important;
    font-size: 12px !important;
    line-height: 1.6 !important;
    white-space: pre !important;
  }
  .sk-prose pre code {
    background: transparent !important;
    padding: 0 !important;
    color: inherit !important;
    font-size: inherit !important;
  }
  .sk-prose hr {
    display: block !important;
    border: none !important;
    border-top: 1px solid #e5e7eb !important;
    margin: 10px 0 !important;
  }

  /* ── Sources section ── */
  .sk-sources {
    display: flex !important;
    flex-direction: column !important;
    gap: 4px !important;
    padding-top: 8px !important;
    font-size: 12px !important;
    color: #6b7280 !important;
  }
  .sk-sources strong {
    font-weight: 600 !important;
    color: #6b7280 !important;
    margin-bottom: 2px !important;
  }
  .sk-source-link {
    display: block !important;
    color: #6366f1 !important;
    text-decoration: none !important;
    padding: 2px 0 !important;
  }
  .sk-source-link:hover {
    text-decoration: underline !important;
  }

  /* ── Typing indicator ── */
  .sk-typing {
    display: flex !important;
    gap: 5px !important;
    align-items: center !important;
    padding: 6px 2px !important;
    background: transparent !important;
  }
  .sk-typing span {
    display: block !important;
    width: 7px !important;
    height: 7px !important;
    border-radius: 50% !important;
    background: #9ca3af !important;
    animation: sk-bounce 1.1s ease-in-out infinite !important;
  }
  .sk-typing span:nth-child(2) {
    animation-delay: 0.18s !important;
  }
  .sk-typing span:nth-child(3) {
    animation-delay: 0.36s !important;
  }
  @keyframes sk-bounce {
    0%,
    60%,
    100% {
      transform: translateY(0);
      opacity: 0.6;
    }
    30% {
      transform: translateY(-6px);
      opacity: 1;
    }
  }

  /* ── Suggestion pills ── */
  #sk-suggestions {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 8px !important;
    margin-top: 4px !important;
  }
  .sk-suggestion {
    display: inline-block !important;
    padding: 6px 12px !important;
    background: #fff !important;
    border: 1px solid #e5e7eb !important;
    border-radius: 999px !important;
    font-size: 12.5px !important;
    color: #4b5563 !important;
    cursor: pointer !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    transition:
      border-color 0.15s,
      color 0.15s !important;
    white-space: nowrap !important;
    line-height: 1.4 !important;
  }
  .sk-suggestion:hover {
    border-color: #6366f1 !important;
    color: #6366f1 !important;
  }

  /* ── Input area ── */
  #sk-input-area {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    padding: 12px 14px !important;
    border-top: 1px solid #f3f4f6 !important;
    flex-shrink: 0 !important;
    background: #fff !important;
  }
  #sk-input {
    flex: 1 !important;
    height: 38px !important;
    padding: 0 13px !important;
    border: 1px solid #e5e7eb !important;
    border-radius: 10px !important;
    font-size: 13.5px !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    background: #f9fafb !important;
    color: #111827 !important;
    outline: none !important;
    transition:
      border-color 0.15s,
      background 0.15s !important;
  }
  #sk-input:focus {
    border-color: #6366f1 !important;
    background: #fff !important;
  }
  #sk-input::placeholder {
    color: #9ca3af !important;
  }

  #sk-send {
    width: 38px !important;
    height: 38px !important;
    border-radius: 10px !important;
    background: #6366f1 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    color: white !important;
    flex-shrink: 0 !important;
    transition:
      background 0.15s,
      opacity 0.15s !important;
  }
  #sk-send:hover:not([disabled]) {
    background: #4f46e5 !important;
  }
  #sk-send[disabled] {
    opacity: 0.35 !important;
    cursor: not-allowed !important;
  }
</style>

<script define:vars={{ chatApiUrl }}>
  const overlay = document.getElementById('sk-overlay')
  const trigger = document.getElementById('sk-trigger')
  const closeBtn = document.getElementById('sk-modal-close')
  const messages = document.getElementById('sk-messages')
  const input = document.getElementById('sk-input')
  const sendBtn = document.getElementById('sk-send')
  const suggestions = document.getElementById('sk-suggestions')

  let sessionId = `sess_${Date.now()}`
  let isStreaming = false

  // ── Open / close ──
  function openWidget() {
    overlay.classList.add('sk-open')
    overlay.setAttribute('aria-hidden', 'false')
    input.focus()
  }
  function closeWidget() {
    overlay.classList.remove('sk-open')
    overlay.setAttribute('aria-hidden', 'true')
  }

  trigger.addEventListener('click', openWidget)
  closeBtn.addEventListener('click', closeWidget)
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeWidget()
  })
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      overlay.classList.contains('sk-open') ? closeWidget() : openWidget()
    }
    if (e.key === 'Escape' && overlay.classList.contains('sk-open')) closeWidget()
  })

  // ── Suggestions ──
  suggestions.addEventListener('click', (e) => {
    const btn = e.target.closest('.sk-suggestion')
    if (!btn) return
    input.value = btn.dataset.q
    sendBtn.disabled = false
    sendMessage()
  })

  input.addEventListener('input', () => {
    sendBtn.disabled = !input.value.trim() || isStreaming
  })
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey && !sendBtn.disabled) sendMessage()
  })
  sendBtn.addEventListener('click', sendMessage)

  function scrollToBottom() {
    messages.scrollTop = messages.scrollHeight
  }

  // ── Markdown renderer ──
  function escHtml(s) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  }
  function inlineMd(text) {
    return escHtml(text)
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\*\*([^*\n]+)\*\*/g, '<strong>$1</strong>')
      .replace(/\*([^*\n]+)\*/g, '<em>$1</em>')
      .replace(
        /\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g,
        '<a href="$2" target="_blank" rel="noopener">$1</a>',
      )
  }
  function renderMarkdown(text) {
    const lines = text.split('\n')
    let html = ''
    let i = 0
    let inSources = false

    while (i < lines.length) {
      const line = lines[i]

      // Entering sources section: hr followed by **Sources:**
      if (/^[-*_]{3,}$/.test(line.trim())) {
        // Peek ahead — if next non-empty line is **Sources:**, start sources block
        let j = i + 1
        while (j < lines.length && lines[j].trim() === '') j++
        if (j < lines.length && /^\*\*Sources:\*\*/.test(lines[j])) {
          html += '<div class="sk-sources"><strong>Sources</strong>'
          inSources = true
          i = j + 1 // skip the hr and the **Sources:** label line
          continue
        }
        html += '<hr>'
        i++
        continue
      }

      // Inside sources section: each non-empty line is a source link
      if (inSources) {
        if (line.trim() === '') {
          i++
          continue
        }
        // Render the link inline, wrapped in an anchor block
        const linkMatch = line.match(/^\[([^\]]+)\]\((https?:\/\/[^)]+)\)/)
        if (linkMatch) {
          html += `<a class="sk-source-link" href="${linkMatch[2]}" target="_blank" rel="noopener">${escHtml(linkMatch[1])}</a>`
        } else {
          html += `<span>${inlineMd(line)}</span>`
        }
        i++
        continue
      }

      // Fenced code block
      if (line.startsWith('```')) {
        let code = ''
        i++
        while (i < lines.length && !lines[i].startsWith('```')) {
          code += escHtml(lines[i]) + '\n'
          i++
        }
        html += `<pre><code>${code.trimEnd()}</code></pre>`
        i++
        continue
      }
      // Headings
      const hm = line.match(/^(#{1,3}) (.+)/)
      if (hm) {
        const n = hm[1].length
        html += `<h${n}>${inlineMd(hm[2])}</h${n}>`
        i++
        continue
      }
      // Unordered list
      if (/^[-*+] /.test(line)) {
        html += '<ul>'
        while (i < lines.length && /^[-*+] /.test(lines[i])) {
          html += `<li>${inlineMd(lines[i].replace(/^[-*+] /, ''))}</li>`
          i++
        }
        html += '</ul>'
        continue
      }
      // Ordered list
      if (/^\d+\. /.test(line)) {
        html += '<ol>'
        while (i < lines.length && /^\d+\. /.test(lines[i])) {
          html += `<li>${inlineMd(lines[i].replace(/^\d+\. /, ''))}</li>`
          i++
        }
        html += '</ol>'
        continue
      }
      // Blank line
      if (line.trim() === '') {
        i++
        continue
      }
      // Paragraph
      html += `<p>${inlineMd(line)}</p>`
      i++
    }

    if (inSources) html += '</div>'
    return html
  }

  // ── Messaging ──
  function appendUserMessage(text) {
    const wrap = document.createElement('div')
    wrap.className = 'sk-msg sk-msg-user'
    const bubble = document.createElement('div')
    bubble.className = 'sk-bubble'
    bubble.textContent = text
    wrap.appendChild(bubble)
    messages.appendChild(wrap)
    scrollToBottom()
  }

  function showTyping() {
    const wrap = document.createElement('div')
    wrap.className = 'sk-msg sk-msg-assistant'
    wrap.id = 'sk-typing-wrap'
    wrap.innerHTML =
      '<div class="sk-bubble sk-typing"><span></span><span></span><span></span></div>'
    messages.appendChild(wrap)
    scrollToBottom()
    return wrap
  }

  function createAssistantBubble() {
    const wrap = document.createElement('div')
    wrap.className = 'sk-msg sk-msg-assistant'
    const bubble = document.createElement('div')
    bubble.className = 'sk-bubble sk-prose'
    wrap.appendChild(bubble)
    messages.appendChild(wrap)
    return bubble
  }

  async function sendMessage() {
    const text = input.value.trim()
    if (!text || isStreaming) return

    suggestions.style.display = 'none'
    input.value = ''
    sendBtn.disabled = true
    isStreaming = true

    appendUserMessage(text)
    const typing = showTyping()

    const user = window.__scalekitChatUser
    const headers = {
      'Content-Type': 'application/json',
      ...(user?.email ? { 'x-user-id': user.email } : {}),
      ...(user?.orgId ? { 'x-org-id': user.orgId } : {}),
    }

    let bubble = null
    let accumulated = ''

    try {
      const res = await fetch(`${chatApiUrl}/api/chat`, {
        method: 'POST',
        headers,
        body: JSON.stringify({ message: text, sessionId }),
      })

      if (!res.ok) {
        typing.remove()
        const err = document.createElement('div')
        err.className = 'sk-msg sk-msg-error'
        err.innerHTML = `<div class="sk-bubble">Error ${res.status} — could not reach the docs assistant.</div>`
        messages.appendChild(err)
        scrollToBottom()
        return
      }

      const reader = res.body.getReader()
      const decoder = new TextDecoder()
      let buffer = ''

      while (true) {
        const { done, value } = await reader.read()
        if (done) break
        buffer += decoder.decode(value, { stream: true })
        const lines = buffer.split('\n')
        buffer = lines.pop()

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue
          try {
            const event = JSON.parse(line.slice(6))
            if (event.type === 'token') {
              if (!bubble) {
                typing.remove()
                bubble = createAssistantBubble()
              }
              accumulated += event.data.text
              // Show raw text while streaming for responsiveness
              bubble.textContent = accumulated
              scrollToBottom()
            } else if (event.type === 'done') {
              typing.remove()
              if (bubble && accumulated) bubble.innerHTML = renderMarkdown(accumulated)
              scrollToBottom()
            } else if (event.type === 'error') {
              typing.remove()
              if (!bubble) bubble = createAssistantBubble()
              bubble.className = 'sk-bubble'
              bubble.closest('.sk-msg').className = 'sk-msg sk-msg-error'
              bubble.textContent = event.data.message ?? 'Something went wrong.'
              scrollToBottom()
            }
          } catch (_) {}
        }
      }

      // Fallback: render markdown if no done event received
      if (bubble && accumulated && bubble.textContent === accumulated) {
        bubble.innerHTML = renderMarkdown(accumulated)
        scrollToBottom()
      }
    } catch (_) {
      typing.remove()
      const err = document.createElement('div')
      err.className = 'sk-msg sk-msg-error'
      err.innerHTML =
        '<div class="sk-bubble">Could not connect to the docs assistant. Please try again.</div>'
      messages.appendChild(err)
      scrollToBottom()
    } finally {
      isStreaming = false
      sendBtn.disabled = !input.value.trim()
      input.focus()
    }
  }

  // ScalekitChat.identify() API
  window.ScalekitChat = {
    identify: ({ email, name, orgId, orgName }) => {
      window.__scalekitChatUser = { email, name, orgId, orgName }
    },
  }
</script>
