---
import { Tabs, TabItem, Code } from '@astrojs/starlight/components'

interface Props {
  connector?: string
  toolName?: string
  providerName?: string
  toolInputNode?: string
  toolInputPython?: string
}

const {
  connector = 'your-connection',
  toolName = 'provider_list_tool',
  providerName = 'the provider',
  toolInputNode = '{}',
  toolInputPython = '{}',
} = Astro.props

const nodeCode = `import { ScalekitClient } from '@scalekit-sdk/node'
import 'dotenv/config'

const scalekit = new ScalekitClient(
  process.env.SCALEKIT_ENV_URL,
  process.env.SCALEKIT_CLIENT_ID,
  process.env.SCALEKIT_CLIENT_SECRET,
)
const actions = scalekit.actions

const connector = '${connector}'
const identifier = 'user_123'

// Make your first call
const result = await actions.executeTool({
  connector,
  identifier,
  toolName: '${toolName}',
  toolInput: ${toolInputNode},
})
console.log(result)`

const pythonCode = `import os
from scalekit.client import ScalekitClient
from dotenv import load_dotenv
load_dotenv()

scalekit_client = ScalekitClient(
    env_url=os.getenv("SCALEKIT_ENV_URL"),
    client_id=os.getenv("SCALEKIT_CLIENT_ID"),
    client_secret=os.getenv("SCALEKIT_CLIENT_SECRET"),
)
actions = scalekit_client.actions

connection_name = "${connector}"
identifier = "user_123"

# Make your first call
result = actions.execute_tool(
    tool_input=${toolInputPython},
    tool_name="${toolName}",
    connection_name=connection_name,
    identifier=identifier,
)
print(result)`
---

<Tabs syncKey="tech-stack">
  <TabItem label="Node.js">
    <Code code={nodeCode} lang="typescript" title="quickstart.ts" />
  </TabItem>
  <TabItem label="Python">
    <Code code={pythonCode} lang="python" title="quickstart.py" />
  </TabItem>
</Tabs>
