---
import { secondaryNavConfig, IconLucideCheck } from '../configs/secondary-nav.config'
import {
  getActiveProduct,
  getActiveSecondaryNavId,
  isCurrentPage,
  getDisplayLabel,
  getDisplayIcon,
  type SecondaryNavProps,
} from '../utils/secondary-nav-utils'

import { IconLucideChevronDown as IconChevronDown } from '../utils/icon-map'

const { entry } = Astro.props satisfies SecondaryNavProps

const searchParams = Astro.url.searchParams
const activeProduct = getActiveProduct(Astro.url.pathname, entry?.data?.topic, searchParams)
const activeId = getActiveSecondaryNavId(Astro.url.pathname, entry, searchParams)
const navItems = secondaryNavConfig[activeProduct]
---

<nav class="secondary-nav sl-hidden md:sl-flex" aria-label="Main topics navigation">
  <div class="nav-section nav-left">
    <div class="nav-items">
      {
        navItems.map((item) => {
          const hasDropdown = Boolean(item.children && item.children.length > 0)
          const isCurrent = isCurrentPage(Astro.url.pathname, item, entry, searchParams)
          const IconComponent = hasDropdown
            ? getDisplayIcon(Astro.url.pathname, item, entry, searchParams)
            : item.iconComponent
          const label = hasDropdown
            ? getDisplayLabel(Astro.url.pathname, item, entry, searchParams)
            : item.label
          const itemClass = `nav-item ${isCurrent ? 'current' : ''} ${item.shared ? 'shared' : ''}`

          return (
            <div
              class={`nav-item-wrapper ${hasDropdown ? 'has-dropdown' : ''}`}
              data-keep-parent-label={item.keepParentLabel ? 'true' : undefined}
            >
              {hasDropdown ? (
                <button
                  type="button"
                  class={itemClass}
                  data-nav-key={item.href}
                  aria-expanded="false"
                  aria-current={isCurrent ? 'page' : undefined}
                >
                  <div class="nav-item-content">
                    {IconComponent && <IconComponent class="nav-icon" />}
                    {label && <span class="nav-label">{label}</span>}
                    <IconChevronDown class="dropdown-icon" />
                  </div>
                </button>
              ) : (
                <a
                  href={item.href}
                  class={itemClass}
                  aria-current={isCurrent ? 'page' : undefined}
                  data-astro-prefetch="viewport"
                >
                  <div class="nav-item-content">
                    {IconComponent && <IconComponent class="nav-icon" />}
                    {item.label && <span class="nav-label">{item.label}</span>}
                  </div>
                </a>
              )}
            </div>
          )
        })
      }
    </div>
  </div>
</nav>

<!-- Dropdown portal to ensure menu overlays main content -->
<div id="dropdown-portal" class="dropdown-portal">
  {
    navItems
      .filter((item) => item.children && item.children.length > 0)
      .map((item) => {
        // Check if this dropdown has column groups
        const hasColumnGroups = item.children?.some((child) => child.columnGroup)
        const leftItems = item.children?.filter((child) => child.columnGroup === 'left') || []
        const rightItems = item.children?.filter((child) => child.columnGroup === 'right') || []
        const ungroupedItems = item.children?.filter((child) => !child.columnGroup) || []

        return (
          <div
            class="dropdown-menu"
            data-dropdown
            data-nav-key={item.href}
            data-dropdown-id={item.id}
          >
            <div class={`dropdown-content ${hasColumnGroups ? 'has-columns' : ''}`}>
              {hasColumnGroups ? (
                <div class="dropdown-columns">
                  {leftItems.length > 0 && (
                    <div class="dropdown-column dropdown-column-left">
                      {leftItems.map((child, index) => (
                        <>
                          {index === 0 && child.sectionLabel && (
                            <>
                              <div class="dropdown-section-label">{child.sectionLabel}</div>
                              {child.sectionDescription && (
                                <div class="dropdown-section-description">
                                  {child.sectionDescription}
                                </div>
                              )}
                              {child.sectionHref && child.sectionCtaLabel && (
                                <a href={child.sectionHref} class="dropdown-section-cta">
                                  {child.sectionCtaLabel}
                                </a>
                              )}
                            </>
                          )}
                          <a
                            href={child.href}
                            class={`dropdown-item ${child.description ? 'with-description' : ''} ${isCurrentPage(Astro.url.pathname, child, entry, searchParams) ? 'current' : ''}`}
                            aria-current={
                              isCurrentPage(Astro.url.pathname, child, entry, searchParams)
                                ? 'page'
                                : undefined
                            }
                            data-nav-label={child.label}
                            data-dropdown-label={child.dropdownLabel || child.label}
                            data-astro-prefetch="viewport"
                          >
                            <div class="dropdown-item-icon-wrapper">
                              {(function () {
                                const ChildIcon = child.iconComponent
                                return ChildIcon && <ChildIcon class="dropdown-item-icon" />
                              })()}
                            </div>
                            <div class="dropdown-item-content">
                              <span class="dropdown-item-label">
                                {child.dropdownLabel || child.label}
                              </span>
                              {child.description && (
                                <span class="dropdown-item-description">{child.description}</span>
                              )}
                            </div>
                            <IconLucideCheck class="dropdown-item-check-icon" />
                          </a>
                          {child.showDivider && <div class="dropdown-divider" />}
                        </>
                      ))}
                    </div>
                  )}
                  {leftItems.length > 0 && rightItems.length > 0 && (
                    <div class="dropdown-column-separator" />
                  )}
                  {rightItems.length > 0 && (
                    <div class="dropdown-column dropdown-column-right">
                      {rightItems.map((child, index) => (
                        <>
                          {index === 0 && child.sectionLabel && (
                            <>
                              <div class="dropdown-section-label">{child.sectionLabel}</div>
                              {child.sectionDescription && (
                                <div class="dropdown-section-description">
                                  {child.sectionDescription}
                                </div>
                              )}
                              {child.sectionHref && child.sectionCtaLabel && (
                                <a href={child.sectionHref} class="dropdown-section-cta">
                                  {child.sectionCtaLabel}
                                </a>
                              )}
                            </>
                          )}
                          <a
                            href={child.href}
                            class={`dropdown-item dropdown-item-shortcut ${child.description ? 'with-description' : ''} ${isCurrentPage(Astro.url.pathname, child, entry, searchParams) ? 'current' : ''}`}
                            aria-current={
                              isCurrentPage(Astro.url.pathname, child, entry, searchParams)
                                ? 'page'
                                : undefined
                            }
                            data-nav-label={child.label}
                            data-dropdown-label={child.dropdownLabel || child.label}
                            data-astro-prefetch="viewport"
                          >
                            <div class="dropdown-item-icon-wrapper">
                              {(function () {
                                const ChildIcon = child.iconComponent
                                return ChildIcon && <ChildIcon class="dropdown-item-icon" />
                              })()}
                            </div>
                            <div class="dropdown-item-content">
                              <span class="dropdown-item-label">
                                {child.dropdownLabel || child.label}
                              </span>
                              {child.description && (
                                <span class="dropdown-item-description">{child.description}</span>
                              )}
                            </div>
                            <IconLucideCheck class="dropdown-item-check-icon" />
                          </a>
                          {child.showDivider && <div class="dropdown-divider" />}
                        </>
                      ))}
                    </div>
                  )}
                </div>
              ) : (
                <>
                  {ungroupedItems.map((child) => (
                    <>
                      {child.sectionLabel && (
                        <div class="dropdown-section-label">{child.sectionLabel}</div>
                      )}
                      <a
                        href={child.href}
                        class={`dropdown-item ${child.description ? 'with-description' : ''} ${isCurrentPage(Astro.url.pathname, child, entry, searchParams) ? 'current' : ''}`}
                        aria-current={
                          isCurrentPage(Astro.url.pathname, child, entry, searchParams)
                            ? 'page'
                            : undefined
                        }
                        data-astro-prefetch="viewport"
                      >
                        <div class="dropdown-item-icon-wrapper">
                          {(function () {
                            const ChildIcon = child.iconComponent
                            return ChildIcon && <ChildIcon class="dropdown-item-icon" />
                          })()}
                        </div>
                        <div class="dropdown-item-content">
                          <span class="dropdown-item-label">{child.label}</span>
                          {child.description && (
                            <span class="dropdown-item-description">{child.description}</span>
                          )}
                        </div>
                        <IconLucideCheck class="dropdown-item-check-icon" />
                      </a>
                      {child.showDivider && <div class="dropdown-divider" />}
                    </>
                  ))}
                </>
              )}
            </div>
          </div>
        )
      })
  }
</div>

<style>
  /* Hide the duplicate sidebar topics in the left sidebar on desktop */
  :global(.starlight-sidebar-topics) {
    display: none;
  }

  /* Match header CTA seam (--sk-chrome-bp / 50rem): show topics when secondary nav hides */
  @media (max-width: 50rem) {
    :global(.starlight-sidebar-topics) {
      display: block !important;
    }
  }

  .dropdown-portal {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: var(--sl-z-index-dropdown, 15);
  }

  .secondary-nav {
    /* Parent header is already sticky — flow layout only */
    display: flex;
    align-items: center;
    width: 100%;
    isolation: isolate;
    background-color: var(--sl-color-bg);
    border-bottom: 1px solid var(--sl-color-hairline-shade);
    /* Reserve row height so product-switch soft-nav does not collapse chrome */
    min-height: 2.75rem;
  }

  .nav-section {
    flex: 1;
    display: flex;
    min-width: 0;
    overflow: hidden;
  }

  .nav-left {
    justify-content: flex-start;
  }

  .nav-items {
    font-weight: 500;
    display: flex;
    padding: 0.25rem 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    justify-content: flex-start;
    gap: 0.125rem;
  }

  .nav-items::-webkit-scrollbar {
    display: none;
  }

  .nav-item-wrapper {
    position: relative;
    display: flex;
    isolation: isolate;
  }

  .nav-item {
    display: flex;
    align-items: center;
    margin: 0.25rem 0;
    padding: 0.35rem 0.9rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    white-space: nowrap;
    position: relative;
    line-height: 1;
    box-sizing: border-box;
    border-radius: var(--sk-radius-md, 0.375rem);
    background: transparent;
    border: none;
    font: inherit;
    cursor: pointer;
    transition:
      color 0.15s ease,
      background-color 0.15s ease;
  }

  .nav-item:hover {
    color: var(--sl-color-text);
    background-color: var(--sl-color-gray-6);
  }

  .nav-item:focus-visible {
    outline: var(--sk-focus-ring, 2px solid var(--sl-color-accent));
    outline-offset: var(--sk-focus-offset, 2px);
  }

  .nav-item.current {
    color: var(--sl-color-text);
    background-color: var(--sl-color-gray-6);
    font-weight: 600;
  }

  /* Shared items are temporary — will be split into product-specific entries */
  .nav-item.shared {
    color: var(--sl-color-gray-3);
  }

  .nav-item.shared:hover {
    color: var(--sl-color-text);
  }

  .nav-item-content {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    line-height: 1.2;
  }

  .nav-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .nav-label {
    font-size: var(--sl-text-sm);
    line-height: 1.5;
    text-decoration: none;
  }

  /* Dropdown styles via portal overlay */
  .dropdown-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    transition: transform 0.2s ease;
    margin-left: 0.1rem;
  }

  .nav-item-wrapper.has-dropdown:hover .dropdown-icon,
  .nav-item-wrapper.has-dropdown .nav-item[aria-expanded='true'] .dropdown-icon {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      visibility 0.2s ease;
    z-index: var(--sl-z-index-dropdown, 15);
    pointer-events: none;
    isolation: isolate;
    top: -9999px;
    left: -9999px;
  }

  .dropdown-menu.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: all;
  }

  @media (prefers-reduced-motion: reduce) {
    .dropdown-menu,
    .dropdown-icon,
    .nav-item,
    .dropdown-item,
    .dropdown-item-check-icon {
      transition: none;
    }

    .dropdown-menu {
      transform: none;
    }
  }

  .dropdown-content {
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: var(--sk-radius-lg, 0.5rem);
    box-shadow: var(--sk-shadow-menu);
    padding: 0.75rem 1rem;
    position: relative;
    isolation: isolate;
    min-width: 220px;
    width: 31.875rem;
  }

  /* Wider dropdown for Authenticate (has descriptions) */
  [data-dropdown-id='authenticate'] .dropdown-content {
    width: 31.875rem;
  }

  /* Narrower dropdown for SDKs & APIs */
  [data-dropdown-id='api-reference'] .dropdown-content {
    width: 20rem;
  }

  .dropdown-section-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    padding: 0.5rem 0.25rem 0.25rem 0.25rem;
    letter-spacing: 0.05em;
    line-height: 1.25rem;
  }

  .dropdown-section-description {
    font-size: 0.77rem;
    font-weight: 400;
    color: var(--sl-color-gray-3);
    padding: 0 0.25rem 0.75rem 0.25rem;
    line-height: 1.25rem;
  }

  .dropdown-section-cta {
    display: inline-block;
    margin: -0.2rem 0.25rem 0.75rem 0.25rem;
    color: var(--sl-color-accent-high);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
  }

  .dropdown-section-cta:hover {
    text-decoration: underline;
  }

  .dropdown-item {
    display: flex;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 0.5rem 0.25rem;
    color: var(--sl-color-gray-1);
    text-decoration: none;
    transition:
      color 0.15s ease,
      background-color 0.15s ease;
    border-radius: var(--sk-radius-md, 0.375rem);
    width: 100%;
    position: relative;
  }

  .dropdown-item.with-description {
    padding: 0.5rem 0.25rem;
    min-height: 4rem;
  }

  .dropdown-item:focus-visible {
    outline: var(--sk-focus-ring, 2px solid var(--sl-color-accent));
    outline-offset: var(--sk-focus-offset, 2px);
  }

  .dropdown-item-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--sk-radius-md, 0.375rem);
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .dropdown-item-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .dropdown-item-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 0;
    padding-right: 2rem;
  }

  .dropdown-item-label {
    font-size: var(--sl-text-sm);
    font-weight: 500;
    line-height: 1.5rem;
    color: inherit;
  }

  .dropdown-item-description {
    font-size: 0.875rem;
    line-height: 1.25rem;
    color: var(--sk-color-muted-text, var(--sl-color-gray-3));
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dropdown-item:hover {
    background: var(--sl-color-gray-6);
  }

  .dropdown-item.current {
    background: var(--sl-color-gray-6);
    position: relative;
  }

  .dropdown-item-check-icon {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1rem;
    height: 1rem;
    color: var(--sk-color-success, var(--sl-color-green-high));
    flex-shrink: 0;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.2s ease,
      visibility 0.2s ease;
  }

  .dropdown-item.current .dropdown-item-check-icon {
    opacity: 1;
    visibility: visible;
  }

  .dropdown-item.current .dropdown-item-label {
    font-weight: 600;
  }

  .dropdown-divider {
    height: 1px;
    background: var(--sl-color-gray-5);
    margin: 0.625rem 0;
  }

  /* Two-column layout styles */
  .dropdown-columns {
    display: flex;
    gap: 0;
    position: relative;
  }

  .dropdown-column {
    flex: 1;
    min-width: 0;
    padding: 0 1rem;
  }

  .dropdown-column-left {
    padding-right: 1.5rem;
  }

  .dropdown-column-right {
    padding-left: 1.5rem;
  }

  .dropdown-column-separator {
    width: 1px;
    background: var(--sl-color-gray-5);
    margin: 0.5rem 0;
    flex-shrink: 0;
  }

  .dropdown-content.has-columns {
    width: 48rem;
    padding: 0.75rem 0;
  }

  /* Shortcut item styling - smaller, more compact */
  .dropdown-item-shortcut {
    padding: 0.375rem 0.25rem;
    min-height: auto;
  }

  .dropdown-item-shortcut .dropdown-item-icon-wrapper {
    width: 1.25rem;
    height: 1.25rem;
  }

  .dropdown-item-shortcut .dropdown-item-icon {
    width: 0.875rem;
    height: 0.875rem;
  }

  .dropdown-item-shortcut .dropdown-item-label {
    font-weight: 500;
    line-height: 1.25rem;
  }

  .dropdown-item-shortcut .dropdown-item-description {
    line-height: 1.125rem;
  }

  .dropdown-item-shortcut .dropdown-item-content {
    padding-right: 1.5rem;
  }

  /* Responsive adjustments — hide with header CTA seam at 50rem */
  @media (max-width: 50rem) {
    .secondary-nav {
      display: none !important;
    }
  }

  @media (max-width: 72rem) {
    .nav-item {
      padding: 0.35rem 0.75rem;
    }

    .nav-label {
      font-size: var(--sl-text-xs);
    }

    .nav-left .nav-items {
      margin-left: 0.75rem;
    }
  }
</style>

<script>
  function getTriggerForDropdown(dropdown) {
    const navKey = dropdown.getAttribute('data-nav-key')
    if (!navKey) return null
    return document.querySelector(
      `.nav-item-wrapper.has-dropdown .nav-item[data-nav-key="${navKey}"]`,
    )
  }

  function setTriggerExpanded(dropdown, expanded) {
    const triggerBtn = getTriggerForDropdown(dropdown)
    if (triggerBtn) triggerBtn.setAttribute('aria-expanded', expanded ? 'true' : 'false')
  }

  function positionDropdown(trigger, dropdown) {
    const rect = trigger.getBoundingClientRect()
    const dropdownContent = dropdown.querySelector('.dropdown-content')

    // Position dropdown below the trigger with some spacing
    dropdown.style.top = `${rect.bottom + 8}px`
    dropdown.style.left = `${rect.left}px`

    // Check if dropdown would go off-screen and adjust if needed
    if (dropdownContent) {
      const dropdownRect = dropdownContent.getBoundingClientRect()
      const viewportWidth = window.innerWidth

      if (rect.left + dropdownRect.width > viewportWidth - 20) {
        dropdown.style.left = `${viewportWidth - dropdownRect.width - 20}px`
      }
    }

    dropdown.classList.add('open')
    setTriggerExpanded(dropdown, true)
  }

  function hideDropdown(dropdown) {
    dropdown.classList.remove('open')
    dropdown.style.pointerEvents = 'none'
    setTriggerExpanded(dropdown, false)
    // Use a small delay before moving off-screen to allow animations
    setTimeout(() => {
      if (!dropdown.classList.contains('open')) {
        dropdown.style.top = '-9999px'
        dropdown.style.left = '-9999px'
      }
    }, 200)
  }

  function hideAllDropdowns() {
    document.querySelectorAll('[data-dropdown]').forEach((d) => hideDropdown(d))
  }

  function updateCurrentStateFromPath() {
    const currentPath = window.location.pathname

    // First, remove current class from all dropdown items
    document.querySelectorAll('.dropdown-item.current').forEach((el) => {
      el.classList.remove('current')
    })

    // Find the dropdown item that matches the current path
    let matchingItem: Element | null = null
    let matchingLabel: string | null = null
    let matchingIcon: Node | null = null

    document.querySelectorAll('.dropdown-item').forEach((item) => {
      const href = item.getAttribute('href')
      if (!href) return

      // Normalize paths for comparison
      const normalizedPath = currentPath.replace(/\/+$/, '')
      const normalizedHref = href.replace(/\/+$/, '').split('#')[0] // Remove hash for path matching

      // Check if current path starts with the item's href
      if (normalizedPath.startsWith(normalizedHref) && normalizedHref !== '') {
        // Only update if this is a better match (longer path = more specific)
        if (
          !matchingItem ||
          normalizedHref.length > (matchingItem.getAttribute('href')?.split('#')[0].length || 0)
        ) {
          matchingItem = item
          // Get label from the dropdown-item-label span, or fallback to any span
          const labelSpan = item.querySelector('.dropdown-item-label') || item.querySelector('span')
          matchingLabel = labelSpan?.textContent || null
          // Get the icon from the dropdown item icon wrapper
          const iconEl = item.querySelector('.dropdown-item-icon')
          if (iconEl) {
            matchingIcon = iconEl.cloneNode(true)
          }
        }
      }
    })

    // If we found a matching item, update the parent nav item
    if (matchingItem && matchingLabel) {
      // Mark the matching item as current
      matchingItem.classList.add('current')

      const dropdownMenu = matchingItem.closest('[data-dropdown]')
      if (dropdownMenu) {
        const parentTrigger = getTriggerForDropdown(dropdownMenu)
        if (parentTrigger) {
          parentTrigger.classList.add('current')

          // Check if this is a right column item (Full-stack Auth shortcut)
          const isRightColumnItem = matchingItem.classList.contains('dropdown-item-shortcut')

          // Check if parent has keepParentLabel attribute
          const wrapper = parentTrigger.closest('.nav-item-wrapper')
          const hasKeepParentLabel = wrapper?.hasAttribute('data-keep-parent-label')

          // Only update label and icon if keepParentLabel is not set AND not a right column item
          if (!hasKeepParentLabel && !isRightColumnItem) {
            // Update the label text to match the active child
            const labelEl = parentTrigger.querySelector('.nav-label')
            if (labelEl && matchingLabel) {
              labelEl.textContent = matchingLabel
            }

            // Update the icon to match the active child
            if (matchingIcon) {
              const iconContainer = parentTrigger.querySelector('.nav-icon')
              if (iconContainer) {
                iconContainer.replaceWith(matchingIcon)
                matchingIcon.classList.add('nav-icon')
              }
            }
          }
        }
      }
    }
  }

  function updateCurrentStateFromHash() {
    const hash = window.location.hash
    if (!hash) return

    const currentPath = window.location.pathname + hash

    // First, remove current class from all dropdown items
    document.querySelectorAll('.dropdown-item.current').forEach((el) => {
      el.classList.remove('current')
    })

    // Find the dropdown item that matches the current path with hash
    let matchingItem = null
    let matchingLabel = null
    let matchingIcon = null

    document.querySelectorAll('.dropdown-item').forEach((item) => {
      const href = item.getAttribute('href')
      // Only match items whose href contains the same hash
      // This prevents /apis/ from matching when the hash is #description/sdks
      if (href && href.includes(hash)) {
        matchingItem = item
        // Get label from the dropdown-item-label span, or fallback to any span
        const labelSpan = item.querySelector('.dropdown-item-label') || item.querySelector('span')
        matchingLabel = labelSpan?.textContent
        // Get the icon from the dropdown item icon wrapper
        const iconEl = item.querySelector('.dropdown-item-icon')
        if (iconEl) {
          matchingIcon = iconEl.cloneNode(true)
        }
        item.classList.add('current')
      }
    })

    // If we found a matching item, update the parent nav item
    if (matchingItem && matchingLabel) {
      const dropdownMenu = matchingItem.closest('[data-dropdown]')
      if (dropdownMenu) {
        const parentTrigger = getTriggerForDropdown(dropdownMenu)
        if (parentTrigger) {
          // Ensure parent is marked as current
          parentTrigger.classList.add('current')

          // Check if this is a right column item (Full-stack Auth shortcut)
          const isRightColumnItem = matchingItem.classList.contains('dropdown-item-shortcut')

          // Check if parent has keepParentLabel attribute
          const wrapper = parentTrigger.closest('.nav-item-wrapper')
          const hasKeepParentLabel = wrapper?.hasAttribute('data-keep-parent-label')

          // Only update label and icon if keepParentLabel is not set AND not a right column item
          if (!hasKeepParentLabel && !isRightColumnItem) {
            // Update the label text to match the active child
            const labelEl = parentTrigger.querySelector('.nav-label')
            if (labelEl && matchingLabel) {
              labelEl.textContent = matchingLabel
            }

            // Update the icon to match the active child
            if (matchingIcon) {
              const iconContainer = parentTrigger.querySelector('.nav-icon')
              if (iconContainer) {
                iconContainer.replaceWith(matchingIcon)
                matchingIcon.classList.add('nav-icon')
              }
            }
          }
        }
      }
    }
  }

  /** Abort prior bindings when client-side router swaps the page */
  let secondaryNavAbort = null

  function initSecondaryNav() {
    secondaryNavAbort?.abort()
    secondaryNavAbort = new AbortController()
    const { signal } = secondaryNavAbort

    // Close any dropdown left open from the previous page
    hideAllDropdowns()

    updateCurrentStateFromPath()
    updateCurrentStateFromHash()

    window.addEventListener('hashchange', updateCurrentStateFromHash, { signal })
    window.addEventListener(
      'popstate',
      () => {
        updateCurrentStateFromPath()
        updateCurrentStateFromHash()
      },
      { signal },
    )

    const dropdownTriggers = document.querySelectorAll('.nav-item-wrapper.has-dropdown')
    let currentOpenDropdown = null
    let isClickOpen = false

    dropdownTriggers.forEach((trigger) => {
      const triggerBtn = trigger.querySelector('.nav-item')
      const navKey = triggerBtn?.getAttribute('data-nav-key')
      if (!navKey) return

      const dropdown = document.querySelector(
        `#dropdown-portal [data-dropdown][data-nav-key="${navKey}"]`,
      )
      if (!dropdown) return

      hideDropdown(dropdown)

      let hoverTimeout = null

      trigger.addEventListener(
        'click',
        (e) => {
          e.preventDefault()
          e.stopPropagation()

          if (currentOpenDropdown === dropdown && dropdown.classList.contains('open')) {
            hideDropdown(dropdown)
            currentOpenDropdown = null
            isClickOpen = false
          } else {
            hideAllDropdowns()
            positionDropdown(trigger, dropdown)
            dropdown.style.pointerEvents = 'all'
            currentOpenDropdown = dropdown
            isClickOpen = true
          }
        },
        { signal },
      )

      trigger.addEventListener(
        'mouseenter',
        () => {
          clearTimeout(hoverTimeout)
          if (!isClickOpen) {
            hoverTimeout = setTimeout(() => {
              hideAllDropdowns()
              positionDropdown(trigger, dropdown)
              dropdown.style.pointerEvents = 'all'
              currentOpenDropdown = dropdown
            }, 100)
          }
        },
        { signal },
      )

      trigger.addEventListener(
        'mouseleave',
        () => {
          clearTimeout(hoverTimeout)
          if (currentOpenDropdown === dropdown && !isClickOpen) {
            hoverTimeout = setTimeout(() => {
              if (!dropdown.matches(':hover') && !trigger.matches(':hover')) {
                hideDropdown(dropdown)
                currentOpenDropdown = null
              }
            }, 200)
          }
        },
        { signal },
      )

      dropdown.addEventListener(
        'mouseenter',
        () => {
          clearTimeout(hoverTimeout)
        },
        { signal },
      )

      dropdown.addEventListener(
        'mouseleave',
        () => {
          if (currentOpenDropdown === dropdown && !isClickOpen) {
            hideDropdown(dropdown)
            currentOpenDropdown = null
          }
        },
        { signal },
      )

      dropdown.addEventListener(
        'click',
        (e) => {
          const target = e.target.closest('.dropdown-item')
          if (target) {
            const isRightColumnItem = target.classList.contains('dropdown-item-shortcut')
            const wrapper = triggerBtn.closest('.nav-item-wrapper')
            const hasKeepParentLabel = wrapper?.hasAttribute('data-keep-parent-label')

            if (!hasKeepParentLabel && !isRightColumnItem) {
              const labelSpan =
                target.querySelector('.dropdown-item-label') || target.querySelector('span')
              const clickedLabel = labelSpan?.textContent
              const iconEl = target.querySelector('.dropdown-item-icon')

              if (clickedLabel) {
                const parentLabel = triggerBtn.querySelector('.nav-label')
                if (parentLabel) parentLabel.textContent = clickedLabel
              }

              if (iconEl) {
                const clonedIcon = iconEl.cloneNode(true)
                const parentIcon = triggerBtn.querySelector('.nav-icon')
                if (parentIcon) {
                  parentIcon.replaceWith(clonedIcon)
                  clonedIcon.classList.add('nav-icon')
                }
              }
            }

            hideDropdown(dropdown)
            currentOpenDropdown = null
            isClickOpen = false
          }
        },
        { signal },
      )

      let ticking = false
      const updatePosition = () => {
        if (!ticking && currentOpenDropdown === dropdown && dropdown.classList.contains('open')) {
          requestAnimationFrame(() => {
            positionDropdown(trigger, dropdown)
            ticking = false
          })
          ticking = true
        }
      }

      window.addEventListener('scroll', updatePosition, { passive: true, signal })
      window.addEventListener('resize', updatePosition, { signal })
    })

    document.addEventListener(
      'click',
      (e) => {
        const target = e.target
        if (
          !target.closest('.nav-item-wrapper.has-dropdown') &&
          !target.closest('[data-dropdown]')
        ) {
          hideAllDropdowns()
          currentOpenDropdown = null
          isClickOpen = false
        }
      },
      { signal },
    )

    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') {
          const openTrigger = document.querySelector(
            '.nav-item-wrapper.has-dropdown .nav-item[aria-expanded="true"]',
          )
          hideAllDropdowns()
          currentOpenDropdown = null
          isClickOpen = false
          if (openTrigger instanceof HTMLElement) openTrigger.focus()
        }
      },
      { signal },
    )
  }

  // Initial load + ClientRouter soft navigations (astro:page-load)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSecondaryNav, { once: true })
  } else {
    initSecondaryNav()
  }
  document.addEventListener('astro:page-load', initSecondaryNav)
</script>
