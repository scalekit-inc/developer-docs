---
import { LinkButton } from '@astrojs/starlight/components'
// @ts-ignore: icon-map is a local utility module without TS types
import { IconLucideLogOut as IconLogout, IconLucideUser as IconSignIn } from '../../utils/icon-map'
import { getSession, clearSessionCache } from '../../utils/auth/session-client'

const loginHref = '/auth/login'
---

<div class="auth-cta" data-auth-cta>
  <!-- Sign in (hidden when logged in) -->
  <LinkButton
    href={loginHref}
    variant="primary"
    icon="right-arrow"
    iconPlacement="end"
    class="sk-primary sign-in-btn"
  >
    Sign in
  </LinkButton>

  <!-- Icon-only sign in for medium widths (768px–1100px) -->
  <a href={loginHref} class="sign-in-icon-btn" aria-label="Sign in">
    <IconSignIn aria-hidden="true" class="sign-in-icon" />
  </a>

  <!-- Profile menu (only when logged in) -->
  <div class="profile-menu" data-profile-menu>
    <button class="profile-trigger" data-profile-trigger aria-haspopup="menu" aria-expanded="false">
      <span class="profile-initial" data-profile-initial aria-hidden="true">?</span>
    </button>
    <div class="profile-popover" data-profile-popover role="menu">
      <div class="profile-identity" role="none">
        <div class="profile-name" data-profile-name role="none">
          <!-- Name populated by JS -->
        </div>
        <div class="profile-email" data-profile-email role="none">
          <!-- Email populated by JS -->
        </div>
      </div>
      <a href="/auth/logout" data-sign-out role="menuitem" class="profile-logout">
        <IconLogout aria-hidden="true" class="logout-icon" />
        <span>Sign out</span>
      </a>
    </div>
  </div>
</div>

<script>
  // @ts-nocheck
  const STORAGE_KEY = 'sk_auth_session'

  const readCache = () => {
    try {
      const raw = localStorage.getItem(STORAGE_KEY)
      if (!raw) return null
      return JSON.parse(raw)
    } catch {
      return null
    }
  }

  /** @param {any} session */
  const writeCache = (session) => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(session))
    } catch {}
  }

  const clearCache = () => {
    try {
      localStorage.removeItem(STORAGE_KEY)
    } catch {}
  }

  /** @param {any} expiresAt */
  const isExpired = (expiresAt) => {
    if (!expiresAt) return false
    return Date.now() >= expiresAt
  }

  const normalizeText = (value, maxLength) => {
    if (typeof value !== 'string') return null
    const trimmed = value.trim()
    if (!trimmed) return null
    return trimmed.slice(0, maxLength)
  }

  const getEmail = (data) => {
    const email = data?.user?.email || data?.idTokenClaims?.email
    return normalizeText(email, 254)
  }

  const getName = (data) => {
    const user = data?.user || {}
    const claims = data?.idTokenClaims || {}
    const candidate =
      user.name ||
      (claims.given_name && claims.family_name
        ? `${claims.given_name} ${claims.family_name}`
        : null) ||
      claims.name ||
      null
    return normalizeText(candidate, 200)
  }

  const getSession = async () => {
    const cached = readCache()
    if (cached?.authenticated && !isExpired(cached.expiresAt)) {
      return cached
    }

    clearCache()

    try {
      let response = await fetch('/auth/session', { credentials: 'include' })
      // Attempt refresh when access token has expired
      if (response.status === 401) {
        const refreshResponse = await fetch('/auth/refresh', {
          method: 'POST',
          credentials: 'include',
        })
        if (refreshResponse.ok) {
          response = await fetch('/auth/session', { credentials: 'include' })
        } else {
          clearCache()
          return { authenticated: false }
        }
      }
      if (!response.ok) {
        clearCache()
        return { authenticated: false }
      }

      const data = await response.json()
      if (data?.authenticated) {
        writeCache(data)
      } else {
        clearCache()
      }
      return data
    } catch {
      clearCache()
      return { authenticated: false }
    }
  }

  let authCtaAbort = null

  // Periodically refresh CTA state without re-attaching listeners
  const refreshCtaState = async (cta) => {
    const data = await getSession()
    if (data && data.authenticated) {
      cta.classList.add('is-authenticated')
    } else {
      cta.classList.remove('is-authenticated')
    }
    const profileMenu = cta.querySelector('[data-profile-menu]')
    const nameElement = profileMenu?.querySelector('[data-profile-name]')
    const emailElement = profileMenu?.querySelector('[data-profile-email]')
    const initialElement = profileMenu?.querySelector('[data-profile-initial]')
    if (data?.authenticated && (nameElement || emailElement || initialElement)) {
      const email = getEmail(data)
      const name = getName(data) || email || 'Account'
      const initialSource = email || name
      const initial = initialSource ? String(initialSource).trim().charAt(0).toUpperCase() : '?'
      if (nameElement) nameElement.textContent = name
      if (emailElement) emailElement.textContent = email || 'Account'
      if (initialElement) initialElement.textContent = initial || '?'
    }
  }

  /** @param {Element} cta @param {AbortSignal} signal */
  const updateCta = async (cta, signal) => {
    await refreshCtaState(cta)

    const profileMenu = cta.querySelector('[data-profile-menu]')
    if (!profileMenu) return

    const trigger = profileMenu.querySelector('[data-profile-trigger]')
    const popover = profileMenu.querySelector('[data-profile-popover]')
    const signOutLink = profileMenu.querySelector('[data-sign-out]')
    if (!trigger || !popover) return

    const closeMenu = () => {
      profileMenu.classList.remove('is-open')
      trigger.setAttribute('aria-expanded', 'false')
    }

    const openMenu = () => {
      profileMenu.classList.add('is-open')
      trigger.setAttribute('aria-expanded', 'true')
    }

    trigger.addEventListener(
      'click',
      (event) => {
        event.preventDefault()
        event.stopPropagation()
        if (profileMenu.classList.contains('is-open')) closeMenu()
        else openMenu()
      },
      { signal },
    )

    if (signOutLink) {
      signOutLink.addEventListener(
        'click',
        (event) => {
          event.preventDefault()
          const session = readCache()
          const idToken = session?.idToken || ''
          clearCache()
          window.location.href = `/auth/logout?id_token=${encodeURIComponent(idToken)}`
        },
        { signal },
      )
    }

    document.addEventListener(
      'click',
      (event) => {
        if (!profileMenu.classList.contains('is-open')) return
        if (profileMenu.contains(event.target)) return
        closeMenu()
      },
      { signal },
    )

    document.addEventListener(
      'keydown',
      (event) => {
        if (event.key !== 'Escape') return
        closeMenu()
      },
      { signal },
    )
  }

  function initAuthCta() {
    authCtaAbort?.abort()
    authCtaAbort = new AbortController()
    const { signal } = authCtaAbort
    document.querySelectorAll('[data-auth-cta]').forEach((cta) => updateCta(cta, signal))
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAuthCta, { once: true })
  } else {
    initAuthCta()
  }
  document.addEventListener('astro:page-load', initAuthCta)
</script>

<style>
  .auth-cta :global(.sk-primary) {
    min-height: var(--sk-control-min-height, 2.25rem);
    padding: var(--sk-control-padding-y, 0.4rem) var(--sk-control-padding-x, 1.25rem);
    font-size: var(--sl-text-sm);
    border-radius: var(--sk-radius-md, 0.375rem);
  }

  .auth-cta :global(.sk-primary:focus-visible) {
    outline: var(--sk-focus-ring, 2px solid var(--sl-color-accent));
    outline-offset: var(--sk-focus-offset, 2px);
  }

  /* Sign in button: hidden when logged in */
  .sign-in-btn {
    display: inline-flex;
  }

  .auth-cta.is-authenticated .sign-in-btn {
    display: none;
  }

  /* Icon-only sign in button */
  .sign-in-icon-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: var(--sk-control-min-height, 2.25rem);
    height: var(--sk-control-min-height, 2.25rem);
    flex-shrink: 0;
    border-radius: var(--sk-radius-md, 0.375rem);
    border: 1px solid var(--sl-color-accent);
    color: var(--sl-color-accent);
    text-decoration: none;
  }

  .sign-in-icon {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }

  /* Hidden when authenticated */
  .auth-cta.is-authenticated .sign-in-icon-btn {
    display: none;
  }

  /* At medium widths: swap to icon-only sign in */
  @media (min-width: 48rem) and (max-width: 68.75rem) {
    .sign-in-btn {
      display: none;
    }

    .sign-in-icon-btn {
      display: inline-flex;
      transition:
        background-color 0.2s ease,
        border-color 0.2s ease,
        color 0.2s ease;
    }

    .sign-in-icon-btn:hover {
      background-color: var(--sl-color-gray-6);
      border-color: var(--sl-color-accent);
    }

    .sign-in-icon-btn:focus-visible {
      outline: var(--sk-focus-ring, 2px solid var(--sl-color-accent));
      outline-offset: var(--sk-focus-offset, 2px);
      background-color: var(--sl-color-gray-6);
      border-color: var(--sl-color-accent);
    }
  }

  /* Profile menu: hidden by default, visible when logged in */
  .profile-menu {
    display: none;
    position: relative;
  }

  .auth-cta.is-authenticated .profile-menu {
    display: inline-flex;
  }

  .profile-trigger {
    width: var(--sk-control-min-height, 2.25rem);
    height: var(--sk-control-min-height, 2.25rem);
    border-radius: var(--sk-radius-full, 50%);
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-black);
    cursor: pointer;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    line-height: 1;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .profile-trigger:hover {
    background-color: var(--sl-color-gray-6);
  }

  .profile-trigger:focus-visible {
    outline: var(--sk-focus-ring, 2px solid var(--sl-color-accent));
    outline-offset: var(--sk-focus-offset, 2px);
  }

  .profile-initial {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    text-transform: uppercase;
  }

  .profile-popover {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    min-width: 14rem;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: var(--sk-radius-lg, 0.5rem);
    padding: 0.5rem;
    box-shadow: var(--sk-shadow-menu);
    z-index: var(--sl-z-index-dropdown, 15);
  }

  .profile-menu.is-open .profile-popover {
    display: block;
  }

  .profile-identity {
    padding: 0.5rem 0.75rem;
  }

  .profile-name {
    color: var(--sl-color-text);
    font-size: var(--sl-text-sm);
    font-weight: 600;
    cursor: default;
    user-select: none;
  }

  .profile-email {
    color: var(--sl-color-text);
    font-size: var(--sl-text-sm);
    opacity: 0.8;
    cursor: default;
    user-select: none;
  }

  .profile-popover a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: var(--sk-radius-md, 0.375rem);
    text-decoration: none;
    color: var(--sl-color-text);
  }

  .profile-popover a:hover {
    background: var(--sl-color-gray-6);
  }

  .profile-popover a:focus-visible {
    outline: var(--sk-focus-ring, 2px solid var(--sl-color-accent));
    outline-offset: var(--sk-focus-offset, 2px);
  }

  .logout-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }
</style>
