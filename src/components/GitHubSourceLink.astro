---
/**
 * Quiet source link for SDK install pages.
 * Prefer a compact outline control over Nova LinkButton (too large for this chrome).
 */
interface Props {
  href: string
  /** Override the muted mono slug; defaults to path after github.com/ */
  repo?: string
  /** Visible label. Default: GitHub */
  label?: string
  /** Hide the repo slug (use in tight headers). Default: false */
  compact?: boolean
}

const { href, repo, label = 'GitHub', compact = false } = Astro.props

const repoSlug =
  repo ??
  href
    .replace(/^https?:\/\/github\.com\//i, '')
    .replace(/\/+$/, '')
    .replace(/\.git$/, '')
---

<a
  class:list={['sdk-github-link', 'not-content', { 'sdk-github-link--compact': compact }]}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  title={`Open ${repoSlug} on GitHub`}
>
  <svg
    class="sdk-github-link__mark"
    width="15"
    height="15"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path
      d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
    ></path>
  </svg>
  <span class="sdk-github-link__body">
    <span class="sdk-github-link__label">{label}</span>
    {!compact && <span class="sdk-github-link__repo">{repoSlug}</span>}
  </span>
  <svg
    class="sdk-github-link__ext"
    width="12"
    height="12"
    viewBox="0 0 12 12"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M3.5 1.5H10.5V8.5M10.5 1.5L1.5 10.5"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</a>

<style>
  .sdk-github-link {
    --sdk-gh-ease: cubic-bezier(0.23, 1, 0.32, 1);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    max-width: 100%;
    margin: 0;
    padding: 0.4rem 0.7rem 0.4rem 0.55rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: transparent;
    color: var(--sl-color-text);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.25;
    text-decoration: none;
    box-shadow: none;
    transition:
      border-color 150ms var(--sdk-gh-ease),
      background-color 150ms var(--sdk-gh-ease),
      color 150ms var(--sdk-gh-ease),
      transform 140ms var(--sdk-gh-ease);
  }

  .sdk-github-link__mark {
    flex-shrink: 0;
    width: 0.95rem;
    height: 0.95rem;
    color: var(--sl-color-white, var(--sl-color-text-heading));
    opacity: 0.9;
  }

  .sdk-github-link__body {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    min-width: 0;
  }

  .sdk-github-link__label {
    flex-shrink: 0;
    color: var(--sl-color-white, var(--sl-color-text-heading));
    letter-spacing: -0.01em;
  }

  .sdk-github-link__repo {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: var(--sl-font-mono, var(--__sl-font-mono, ui-monospace, monospace));
    font-size: 0.75rem;
    font-weight: 450;
    letter-spacing: -0.015em;
    color: var(--sl-color-text-muted);
  }

  .sdk-github-link__ext {
    flex-shrink: 0;
    width: 0.7rem;
    height: 0.7rem;
    color: var(--sl-color-text-muted);
    opacity: 0.85;
    transition:
      transform 140ms var(--sdk-gh-ease),
      color 150ms var(--sdk-gh-ease),
      opacity 150ms var(--sdk-gh-ease);
  }

  @media (hover: hover) and (pointer: fine) {
    .sdk-github-link:hover {
      border-color: var(--sl-color-gray-4);
      background: var(--sl-color-gray-7, var(--sl-color-bg));
    }

    .sdk-github-link:hover .sdk-github-link__ext {
      color: var(--sl-color-accent);
      opacity: 1;
      transform: translate(1px, -1px);
    }
  }

  .sdk-github-link:active {
    transform: scale(0.97);
  }

  .sdk-github-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .sdk-github-link,
    .sdk-github-link__ext {
      transition: none;
    }

    .sdk-github-link:active {
      transform: none;
    }

    .sdk-github-link:hover .sdk-github-link__ext {
      transform: none;
    }
  }

  @media (max-width: 30rem) {
    .sdk-github-link__repo {
      display: none;
    }
  }
</style>
