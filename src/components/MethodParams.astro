---
interface Param {
  name: string
  type: string
  required?: boolean
  description?: string
}

interface Props {
  params: Param[]
  label?: string
}

const { params, label } = Astro.props

function typeClass(type: string): string {
  const t = type.toLowerCase()
  if (t === 'bool' || t === 'boolean') return 'type-boolean'
  if (t === 'int' || t === 'integer') return 'type-integer'
  if (t === 'float' || t === 'number') return 'type-number'
  if (t === 'dict' || t.startsWith('dict[') || t.startsWith('record<') || t === 'object')
    return 'type-object'
  if (t === 'list' || t.startsWith('list[') || t === 'array' || t.endsWith('[]'))
    return 'type-array'
  if (t === 'str' || t.includes('string')) return 'type-string'
  return 'type-any'
}
---

{label && <div class="schema-label not-content">{label}</div>}
<div class="method-params not-content">
  <div class="params-header">
    <span>Name</span>
    <span>Type</span>
    <span>Required</span>
    <span>Description</span>
  </div>
  {
    params.map((p) => (
      <div class="param-row">
        <span class="param-name">{p.name}</span>
        <span class={`type-chip ${typeClass(p.type)}`}>{p.type}</span>
        <span class={`req-badge ${p.required ? 'is-required' : 'is-optional'}`}>
          {p.required ? 'required' : 'optional'}
        </span>
        <span class="param-desc">{p.description ?? ''}</span>
      </div>
    ))
  }
</div>

<style>
  .schema-label {
    font-family: var(--sl-font-system-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-4);
    margin-bottom: 0.375rem;
    padding: 0 0.25rem;
  }

  .method-params {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin: 1rem 0 1.25rem;
  }

  .params-header {
    display: grid;
    grid-template-columns: 14rem 9rem 5.5rem 1fr;
    gap: 0.75rem;
    padding: 0 0.75rem 0.5rem;
    font-family: var(--sl-font-system-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-4);
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .param-row {
    display: grid;
    grid-template-columns: 14rem 9rem 5.5rem 1fr;
    align-items: start;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.4375rem;
  }

  .param-name {
    font-family: var(--sl-font-system-mono);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    color: var(--sl-color-text);
    border: none;
    word-break: break-all;
  }

  .type-chip {
    font-family: var(--sl-font-system-mono);
    font-size: 0.625rem;
    font-weight: 500;
    padding: 0.125rem 0.5rem;
    border-radius: 0.3125rem;
    width: fit-content;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .type-string {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    border: 1px solid rgba(59, 130, 246, 0.2);
  }
  .type-boolean {
    background: rgba(168, 85, 247, 0.1);
    color: #a855f7;
    border: 1px solid rgba(168, 85, 247, 0.2);
  }
  .type-integer {
    background: rgba(245, 158, 11, 0.1);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.2);
  }
  .type-number {
    background: rgba(249, 115, 22, 0.1);
    color: #f97316;
    border: 1px solid rgba(249, 115, 22, 0.2);
  }
  .type-object {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.2);
  }
  .type-array {
    background: rgba(20, 184, 166, 0.1);
    color: #14b8a6;
    border: 1px solid rgba(20, 184, 166, 0.2);
  }
  .type-any {
    background: rgba(107, 114, 128, 0.1);
    color: #6b7280;
    border: 1px solid rgba(107, 114, 128, 0.2);
  }

  .req-badge {
    font-family: var(--sl-font-system-mono);
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 0.3125rem;
    width: fit-content;
  }
  .is-required {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }
  .is-optional {
    background: color-mix(in srgb, var(--sl-color-hairline) 55%, transparent);
    color: color-mix(in srgb, var(--sl-color-text) 62%, var(--sl-color-bg) 38%);
    border: 1px solid color-mix(in srgb, var(--sl-color-hairline) 70%, transparent);
    font-weight: 500;
  }

  .param-desc {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }

  @media (max-width: 52rem) {
    .params-header,
    .param-row {
      grid-template-columns: 1fr 6rem;
    }
    .params-header span:nth-child(3),
    .params-header span:nth-child(4),
    .param-row .req-badge,
    .param-row .param-desc {
      display: none;
    }
  }
</style>
