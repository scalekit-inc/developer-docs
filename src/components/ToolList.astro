---
import type { Tool } from '../types/agent-connectors'

interface Props {
  tools: Tool[]
}

const { tools } = Astro.props
---

<div class="tool-list not-content">
  {
    tools.map((tool, i) => (
      <details class="tool-card" id={tool.name} open={i === 0 || undefined}>
        <summary class="tool-header">
          <code class="tool-name">{tool.name}</code>
          <span class="tool-inline-desc">{tool.description}</span>
          <span class="tool-param-badge">
            {tool.params.length} param{tool.params.length !== 1 ? 's' : ''}
          </span>
          <span class="tool-chevron" aria-hidden="true">
            ▾
          </span>
        </summary>
        <div class="tool-body">
          <p class="tool-desc">{tool.description}</p>
          {tool.params.length > 0 && (
            <div class="params-grid">
              <div class="params-header">
                <span>Name</span>
                <span>Type</span>
                <span>Required</span>
                <span>Description</span>
              </div>
              {tool.params.map((param) => (
                <div class="param-row">
                  <code class="param-name">{param.name}</code>
                  <span class={`type-chip type-${param.type}`}>{param.type}</span>
                  <span class={`req-badge ${param.required ? 'is-required' : 'is-optional'}`}>
                    {param.required ? 'required' : 'optional'}
                  </span>
                  <span class="param-desc">{param.description}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      </details>
    ))
  }
</div>

<style>
  .tool-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tool-card summary {
    list-style: none;
  }
  .tool-card summary::-webkit-details-marker {
    display: none;
  }

  .tool-card {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.625rem;
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .tool-card[open] {
    border-color: var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-text-accent) 6%, var(--sl-color-bg-nav));
  }

  .tool-header {
    display: grid;
    grid-template-columns: auto 1fr auto 1rem;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.125rem;
    cursor: pointer;
    user-select: none;
  }

  .tool-name {
    font-family: var(--sl-font-system-mono);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    color: var(--sl-color-text);
    background: none;
    padding: 0;
    border: none;
  }

  .tool-inline-desc {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .tool-param-badge {
    font-family: var(--sl-font-system-mono);
    font-size: 0.625rem;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline);
    padding: 0.125rem 0.5rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .tool-chevron {
    font-size: 1rem;
    color: var(--sl-color-gray-2);
    transition: transform 0.2s;
    justify-self: end;
    line-height: 1;
  }
  .tool-card[open] .tool-chevron {
    transform: rotate(180deg);
    color: var(--sl-color-text-accent);
  }

  .tool-body {
    border-top: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg);
  }

  .tool-desc {
    padding: 0.75rem 1.125rem;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
    border-bottom: 1px solid var(--sl-color-hairline);
    margin: 0;
  }

  .params-grid {
    padding: 0.875rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .params-header {
    display: grid;
    grid-template-columns: 12rem 5.5rem 5rem 1fr;
    gap: 0.75rem;
    padding: 0 0.75rem 0.5rem;
    font-family: var(--sl-font-system-mono);
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sl-color-gray-4);
  }

  .param-row {
    display: grid;
    grid-template-columns: 12rem 5.5rem 5rem 1fr;
    align-items: start;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.4375rem;
  }

  .param-name {
    font-family: var(--sl-font-system-mono);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    color: var(--sl-color-text);
    background: none;
    padding: 0;
    border: none;
    word-break: break-all;
  }

  .type-chip {
    font-family: var(--sl-font-system-mono);
    font-size: 0.625rem;
    font-weight: 500;
    padding: 0.125rem 0.5rem;
    border-radius: 0.3125rem;
    width: fit-content;
  }
  .type-string {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    border: 1px solid rgba(59, 130, 246, 0.2);
  }
  .type-boolean {
    background: rgba(168, 85, 247, 0.1);
    color: #a855f7;
    border: 1px solid rgba(168, 85, 247, 0.2);
  }
  .type-integer {
    background: rgba(245, 158, 11, 0.1);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.2);
  }
  .type-object {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.2);
  }
  .type-number {
    background: rgba(249, 115, 22, 0.1);
    color: #f97316;
    border: 1px solid rgba(249, 115, 22, 0.2);
  }
  .type-array {
    background: rgba(20, 184, 166, 0.1);
    color: #14b8a6;
    border: 1px solid rgba(20, 184, 166, 0.2);
  }

  .req-badge {
    font-family: var(--sl-font-system-mono);
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 0.3125rem;
    width: fit-content;
  }
  .is-required {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }
  .is-optional {
    color: var(--sl-color-gray-4);
    font-weight: 400;
  }

  .param-desc {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }

  @media (max-width: 48rem) {
    .tool-header {
      grid-template-columns: 1fr auto 1rem;
    }
    .tool-inline-desc {
      display: none;
    }

    .params-header,
    .param-row {
      grid-template-columns: 1fr 1fr;
    }
    .params-header span:nth-child(3),
    .params-header span:nth-child(4),
    .param-row .req-badge,
    .param-row .param-desc {
      display: none;
    }
  }
</style>

<script>
  // Inject tool names into Starlight's right-sidebar TOC
  document.addEventListener('DOMContentLoaded', () => {
    const tocNav = document.querySelector<HTMLElement>('starlight-toc nav > ul')
    if (!tocNav) return

    const toolListLink = Array.from(
      tocNav.querySelectorAll<HTMLAnchorElement>(':scope > li a'),
    ).find((a) => a.getAttribute('href') === '#tool-list')
    if (!toolListLink) return
    const toolListItem = toolListLink.closest('li')
    if (!toolListItem) return

    const cards = document.querySelectorAll<HTMLElement>('.tool-list .tool-card[id]')
    if (!cards.length) return

    const nestedUl = document.createElement('ul')
    nestedUl.style.cssText =
      'list-style:none;padding-inline-start:1rem;margin:0.25rem 0 0;display:flex;flex-direction:column;gap:0.125rem;'

    cards.forEach((card) => {
      const name = card.querySelector('.tool-name')?.textContent?.trim() ?? card.id
      const li = document.createElement('li')
      const a = document.createElement('a')
      a.href = `#${card.id}`
      a.textContent = name
      a.style.cssText =
        'font-size:var(--sl-text-xs);font-family:var(--sl-font-system-mono);color:var(--sl-color-gray-2);text-decoration:none;display:block;padding:0.125rem 0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;'
      a.addEventListener('mouseenter', () => (a.style.color = 'var(--sl-color-text-accent)'))
      a.addEventListener('mouseleave', () => (a.style.color = 'var(--sl-color-gray-2)'))
      a.addEventListener('click', (e) => {
        e.preventDefault()
        const target = document.getElementById(card.id) as HTMLDetailsElement | null
        if (target) {
          target.open = true
          target.scrollIntoView({ behavior: 'smooth', block: 'start' })
          history.pushState(null, '', `#${card.id}`)
        }
      })
      li.appendChild(a)
      nestedUl.appendChild(li)
    })

    toolListItem.appendChild(nestedUl)
  })

  // Open and scroll to the target tool when navigating directly via URL hash
  function openFromHash(): void {
    const hash = location.hash.slice(1)
    if (!hash) return
    const target = document.querySelector<HTMLDetailsElement>(`.tool-card#${CSS.escape(hash)}`)
    if (target) {
      target.open = true
      setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50)
    }
  }

  openFromHash()
  window.addEventListener('hashchange', openFromHash)
</script>
