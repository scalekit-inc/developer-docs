---
import { getCollection } from 'astro:content'
import { LinkCard } from '@astrojs/starlight/components'
import ResponsiveCardGrid from '@components/ui/ResponsiveCardGrid.astro'

const connectors = await getCollection('docs', ({ id }) =>
  id.startsWith('reference/agent-connectors/'),
)
const sorted = [...connectors].sort((a, b) =>
  (a.data.title || '').localeCompare(b.data.title || ''),
)
---

<div class="agent-connectors-search-container mt-4 mb-6">
  <input
    type="search"
    id="agent-connector-search"
    placeholder="Search for an agent connector..."
    class="search-input"
  />
</div>

<ResponsiveCardGrid columnsMobile={1} columnsTablet={2} columnsDesktop={3} columnsLarge={3}>
  {
    sorted.map((entry) => (
      <div
        class="connector-card-wrapper"
        data-title={(entry.data.title || '').toLowerCase()}
        data-description={(entry.data.description || '').toLowerCase()}
      >
        <LinkCard
          title={entry.data.title}
          href={`/${entry.id}/`}
          description={entry.data.description}
        />
      </div>
    ))
  }
</ResponsiveCardGrid>

<style>
  .search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    font-size: var(--sl-text-base);
    transition: border-color 0.2s ease;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--sl-color-text-accent);
    background: var(--sl-color-black);
  }

  .connector-card-wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
    margin-top: 0 !important;
  }
  .connector-card-wrapper > :global(*) {
    flex: 1;
    height: 100%;
  }
</style>

<script>
  function setupSearch() {
    const searchInput = document.getElementById('agent-connector-search') as HTMLInputElement | null
    const cards = document.querySelectorAll('.connector-card-wrapper')

    if (!searchInput) return

    searchInput.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement
      const searchTerm = target.value.toLowerCase().trim()

      cards.forEach((card) => {
        const el = card as HTMLElement
        const title = el.getAttribute('data-title') || ''
        const description = el.getAttribute('data-description') || ''

        if (title.includes(searchTerm) || description.includes(searchTerm)) {
          el.style.display = 'flex'
        } else {
          el.style.display = 'none'
        }
      })
    })
  }

  // Setup on load
  setupSearch()
  // Setup on view transitions if used
  document.addEventListener('astro:page-load', setupSearch)
</script>
