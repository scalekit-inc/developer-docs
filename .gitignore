# Keep shared agents + speckit.constitution.md but ignore the rest of .claude/
# Note: use .claude/* (not .claude/) so the ! exceptions below can re-include
# specific subpaths — git cannot re-include files under a fully-excluded dir.
.claude/*
!.claude/agents/
!.claude/agents/**
!.claude/commands/
.claude/commands/*
!.claude/commands/speckit.constitution.md
.planning/
nanobanana-output/

# Agent skills
.agents/
skills-lock.json

.windsurf/
.tmp/
.superpowers/
.firebase/
docs/superpowers/
.worktrees

# Local Python virtual environments (never commit)
venv/
.venv/
examples/*
project-docs/BUILD_AUDIT.md
project-docs/BUILD_COMPARISON.md
